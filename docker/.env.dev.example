# ---------------------------------------------------------------
# HandlujZTym — Dev environment template
# Copy to docker/.env.dev and fill in values.
# NEVER commit .env.dev to version control.
# ---------------------------------------------------------------

# ── PostgreSQL ──────────────────────────────────────────────────
PGHOST=pgdatabase
PGPORT=5432
PGDATABASE=handlujztym_dev
PGUSER=handluj_dev
PGPASSWORD=change_me_dev_password

# ── pgAdmin ─────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@localhost
PGADMIN_PASSWORD=change_me_pgadmin_dev

# ── PayU (sandbox) ──────────────────────────────────────────────
PayU__BaseUrl=https://secure.snd.payu.com
PayU__ClientId=YOUR_SANDBOX_CLIENT_ID
PayU__ClientSecret=YOUR_SANDBOX_CLIENT_SECRET
PayU__MerchantPosId=YOUR_SANDBOX_POS_ID
PayU__NotifyUrl=https://YOUR_DEV_DOMAIN/Payment/Notify

# ── Email (use Mailpit or similar local SMTP catcher) ───────────
EmailSettings__SmtpServer=localhost
EmailSettings__Port=1025
EmailSettings__SenderEmail=noreply@localhost
EmailSettings__SenderName=HandlujZTym Dev
EmailSettings__Password=
