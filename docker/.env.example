# ---------------------------------------------------------------
# HandlujZTym — Docker environment template
# Copy this file to docker/.env and fill in all values.
# NEVER commit .env to version control.
# ---------------------------------------------------------------

# ── PostgreSQL ──────────────────────────────────────────────────
PGHOST=pgdatabase
PGPORT=5432
PGDATABASE=handlujztym
PGUSER=handluj
PGPASSWORD=change_me_strong_password

# ── pgAdmin ─────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_me_pgadmin_password

# ── PayU ────────────────────────────────────────────────────────
# Sandbox: https://secure.snd.payu.com
# Production: https://secure.payu.com
PayU__BaseUrl=https://secure.snd.payu.com
PayU__ClientId=YOUR_PAYU_CLIENT_ID
PayU__ClientSecret=YOUR_PAYU_CLIENT_SECRET
PayU__MerchantPosId=YOUR_PAYU_POS_ID
PayU__NotifyUrl=https://YOUR_DOMAIN/Payment/Notify

# ── Email / SMTP ────────────────────────────────────────────────
EmailSettings__SmtpServer=smtp.example.com
EmailSettings__Port=587
EmailSettings__SenderEmail=noreply@example.com
EmailSettings__SenderName=HandlujZTym
EmailSettings__Password=YOUR_SMTP_PASSWORD
