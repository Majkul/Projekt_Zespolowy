@model List<ProjektZespolowyGr3.Models.DbModels.User>

@if (ViewBag.SelectedTab == "Users")
{
    <form asp-action="Index" method="get" class="row g-2 align-items-center mb-3">
        <input type="hidden" name="tab" value="Users" />

        <div class="col-12 col-md">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" name="searchString" class="form-control"
                       placeholder="Szukaj użytkownika..." value="@ViewBag.CurrentFilter" />
                <button type="submit" class="btn btn-primary">Szukaj</button>
            </div>
        </div>

        <div class="col-auto">
            <label for="pageSize" class="form-label mb-0 small text-secondary">Limit wyników</label>
        </div>
        <div class="col-auto">
            @{
                int currentPageSize = ViewBag.CurrentPageSize ?? 25;
                int[] sizes = new[] { 25, 50, 100, 500, 1000 };
            }
            <select id="pageSize" name="pageSize" class="form-select" style="width: 90px;" onchange="this.form.submit()">
                @foreach (var size in sizes)
                {
                    <option value="@size" selected="@(size == currentPageSize ? "selected" : null)">@size</option>
                }
            </select>
        </div>
    </form>
}

<div class="table-responsive">
    <table class="table table-vcenter card-table">
        <thead>
            <tr>
                <th>Login</th>
                <th>Email</th>
                <th>Imię</th>
                <th>Nazwisko</th>
                <th>Numer telefonu</th>
                <th>Zbanowany</th>
                <th>Usunięty</th>
                <th>Utworzono</th>
                <th class="w-1">Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-break-anywhere">
                        <a asp-controller="UserProfile" asp-action="Details" asp-route-username="@item.Username" class="text-decoration-none fw-bold">
                            @item.Username
                        </a>
                    </td>
                    <td class="text-secondary text-break-anywhere">@item.Email</td>
                    <td class="text-break-anywhere">@item.FirstName</td>
                    <td class="text-break-anywhere">@item.LastName</td>
                    <td class="text-break-anywhere">@item.PhoneNumber</td>
                    <td><span class="badge @(item.IsBanned ? "bg-red-lt" : "bg-green-lt")">@(item.IsBanned ? "Tak" : "Nie")</span></td>
                    <td><span class="badge @(item.IsDeleted ? "bg-red-lt" : "bg-green-lt")">@(item.IsDeleted ? "Tak" : "Nie")</span></td>
                    <td class="text-secondary">@item.CreatedAt.ToString("dd.MM.yyyy")</td>
                    <td>
                        <div class="btn-list flex-nowrap">
                            <a asp-action="EditUser" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edytuj</a>
                            <form asp-action="DeleteUser" asp-route-id="@item.Id" method="post" asp-antiforgery="true" onsubmit="return confirm('Czy na pewno chcesz usunąć tego użytkownika?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Usuń</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
