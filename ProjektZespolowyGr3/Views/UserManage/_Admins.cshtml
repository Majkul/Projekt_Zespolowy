@model List<ProjektZespolowyGr3.Models.DbModels.User>

<h2 class="mb-4">Administratorzy</h2>
<table class="table table-striped table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th scope="col">Id</th>
            <th scope="col">Login</th>
            <th scope="col">Email</th>
            <th scope="col">Zbanowany</th>
            <th scope="col">Utworzono</th>
            <th scope="col" style="width: 140px;">Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>
                    <a asp-controller="UserProfile" asp-action="Details" asp-route-username="@item.Username" class="text-decoration-none">
                        @item.Username
                    </a>
                </td>
                <td>@item.Email</td>
                <td>@item.IsBanned</td>
                <td>@item.CreatedAt</td>
                <td>
                    <a asp-action="EditUser" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-2">Edytuj</a>
                    <form asp-action="DeleteUser" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Czy na pewno chcesz usunąć tego administratora?');">
                        <button type="submit" class="btn btn-sm btn-danger">Usuń</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<a class="btn btn-primary mt-3" asp-controller="UserManage" asp-action="AddAdmin">Dodaj nowego</a>
