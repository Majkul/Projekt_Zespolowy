@model ProjektZespolowyGr3.Models.DbModels.Ticket

@{
    ViewData["Title"] = "Usuń zgłoszenie";
}

<div class="page-header mb-4">
    <h2 class="page-title text-danger">Usuń zgłoszenie</h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-8">
        <div class="card">
            <div class="card-status-top bg-danger"></div>
            <div class="card-body">
                <h3 class="card-title">Czy na pewno chcesz usunąć to zgłoszenie?</h3>

                <dl class="row mb-0">
                    <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.User)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.User.Id)</dd>

                    <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.Category)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.Category)</dd>

                    <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.Status)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.Status)</dd>

                    <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.Subject)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.Subject)</dd>

                    <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.Description)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.Description)</dd>

                    <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.Assignee)</dt>
                    <dd class="col-sm-9">@(Model.Assignee?.Id.ToString() ?? "-")</dd>

                    <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.CreatedAt)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.CreatedAt)</dd>

                    <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.LastActivity)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.LastActivity)</dd>

                    <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.ReportedUser)</dt>
                    <dd class="col-sm-9">@(Model.ReportedUser?.Id.ToString() ?? "-")</dd>

                    <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.ReportedListing)</dt>
                    <dd class="col-sm-9">@(Model.ReportedListing?.Id.ToString() ?? "-")</dd>
                </dl>
            </div>
            <div class="card-footer d-flex gap-2">
                <form asp-action="Delete" class="d-inline">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Usuń</button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary">Powrót do listy</a>
            </div>
        </div>
    </div>
</div>
