@model ProjektZespolowyGr3.Models.DbModels.Ticket
@using System.ComponentModel.DataAnnotations

@{
    ViewData["Title"] = "Szczegóły zgłoszenia";

    string GetDisplayName(Enum value)
    {
        var type = value.GetType();
        var memInfo = type.GetMember(value.ToString());
        if (memInfo.Length > 0)
        {
            var attributes = memInfo[0].GetCustomAttributes(typeof(DisplayAttribute), false);
            if (attributes.Length > 0)
            {
                return ((DisplayAttribute)attributes[0]).Name ?? value.ToString();
            }
        }
        return value.ToString().Replace("_", " ");
    }

    string StatusBadge(TicketStatus s) => s switch
    {
        TicketStatus.Open => "bg-yellow-lt",
        TicketStatus.Resolved => "bg-green-lt",
        TicketStatus.In_Progress => "bg-blue-lt",
        _ => "bg-secondary-lt"
    };
}

<div class="page-header mb-4">
    <h2 class="page-title">Szczegóły zgłoszenia</h2>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title">@Model.Subject</h3>
            </div>
            <div class="card-body">
                <div class="mb-2">
                    <strong>Kategoria:</strong>
                    <span class="badge bg-azure-lt ms-1">@GetDisplayName(Model.Category)</span>
                </div>
                <div class="mb-3">
                    <strong>Status:</strong>
                    <span class="badge @StatusBadge(Model.Status) ms-1">@GetDisplayName(Model.Status)</span>
                </div>
                <hr />
                <div>
                    <strong>Opis:</strong>
                    <p class="mt-2 mb-0">@(string.IsNullOrEmpty(Model.Description) ? "Brak opisu." : Model.Description)</p>
                </div>
            </div>
        </div>

        @if (Model.Attachments != null && Model.Attachments.Any())
        {
            <div class="card mb-3">
                <div class="card-header"><h3 class="card-title">Załączniki</h3></div>
                <div class="list-group list-group-flush">
                    @foreach (var attachment in Model.Attachments)
                    {
                        <div class="list-group-item">
                            @if (attachment.IsDeleted)
                            {
                                <span class="text-secondary"><i class="bi bi-paperclip me-1"></i>Usunięty załącznik</span>
                            }
                            else
                            {
                                <a href="@attachment.Upload.Url" target="_blank" download="@attachment.Upload.FileName">
                                    <i class="bi bi-paperclip me-1"></i>@attachment.Upload.FileName
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header"><h3 class="card-title">Informacje</h3></div>
            <div class="card-body">
                <p>
                    <strong>Zgłoszone przez:</strong>
                    <a asp-controller="UserProfile" asp-action="Details" asp-route-username="@Model.User.Username">@Model.User.Username</a>
                </p>
                <p><strong>Data utworzenia:</strong> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                <p><strong>Ostatnia aktywność:</strong> @Model.LastActivity.ToString("dd.MM.yyyy HH:mm")</p>

                @if (Model.ReportedUser != null)
                {
                    <p>
                        <strong>Zgłoszony użytkownik:</strong>
                        <a asp-controller="UserProfile" asp-action="Details" asp-route-username="@Model.ReportedUser.Username">@Model.ReportedUser.Username</a>
                    </p>
                }
                @if (Model.ReportedListing != null)
                {
                    <p>
                        <strong>Zgłoszona oferta:</strong>
                        <a asp-controller="Listings" asp-action="Details" asp-route-slug="@SlugHelper.GenerateSlug(Model.ReportedListing.Title)" asp-route-id="@Model.ReportedListing.Id">@Model.ReportedListing.Title</a>
                    </p>
                }

                @if (User.Identity?.IsAuthenticated == true && Model.AssigneeId.HasValue && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == Model.AssigneeId.Value.ToString())
                {
                    <hr />
                    <a asp-controller="Messages" asp-action="Conversation" asp-route-userId="@Model.UserId" asp-route-ticketId="@Model.Id" class="btn btn-outline-primary w-100">
                        <i class="bi bi-envelope me-1"></i>Skontaktuj się ze zgłaszającym
                    </a>
                }
            </div>
        </div>

        @if (Model.Assignee != null)
        {
            <div class="card mb-3">
                <div class="card-header"><h3 class="card-title">Przypisane do</h3></div>
                <div class="card-body">@Model.Assignee.Username</div>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">Powrót do listy</a>
</div>
