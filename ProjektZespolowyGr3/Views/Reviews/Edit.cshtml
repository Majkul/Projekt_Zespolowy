@model ProjektZespolowyGr3.Models.DbModels.Review

@{
    ViewData["Title"] = "Edytuj recenzję";
}

<div class="page-header mb-4">
    <h2 class="page-title">Edytuj recenzję</h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="ListingId" class="form-label"></label>
                        <select asp-for="ListingId" class="form-select" asp-items="ViewBag.ListingId"></select>
                        <span asp-validation-for="ListingId" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Rating" class="form-label"></label>
                        <input asp-for="Rating" class="form-control" />
                        <span asp-validation-for="Rating" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ReviewerId" class="form-label"></label>
                        <select asp-for="ReviewerId" class="form-select" asp-items="ViewBag.ReviewerId"></select>
                        <span asp-validation-for="ReviewerId" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <input asp-for="Description" class="form-control" />
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CreatedAt" class="form-label"></label>
                        <input asp-for="CreatedAt" class="form-control" />
                        <span asp-validation-for="CreatedAt" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Upvotes" class="form-label"></label>
                        <input asp-for="Upvotes" class="form-control" />
                        <span asp-validation-for="Upvotes" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Downvotes" class="form-label"></label>
                        <input asp-for="Downvotes" class="form-control" />
                        <span asp-validation-for="Downvotes" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">Zapisz</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Powrót do listy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
