@model ProjektZespolowyGr3.Models.ViewModels.CreateReviewViewModel

@{
    ViewData["Title"] = "Dodaj opinię";
}

<div class="page-header mb-4">
    <h2 class="page-title">Dodaj opinię</h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" enctype="multipart/form-data">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    }

                    <input type="hidden" asp-for="ListingId" />
                    <input type="hidden" asp-for="ListingTitle" />

                    <div class="mb-3">
                        <label asp-for="Rating" class="form-label required">Ocena</label>
                        <select asp-for="Rating" class="form-select">
                            <option value="5">5 ⭐⭐⭐⭐⭐ - Doskonałe</option>
                            <option value="4">4 ⭐⭐⭐⭐ - Bardzo dobre</option>
                            <option value="3">3 ⭐⭐⭐ - Dobre</option>
                            <option value="2">2 ⭐⭐ - Średnie</option>
                            <option value="1">1 ⭐ - Słabe</option>
                        </select>
                        <span asp-validation-for="Rating" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Opis opinii</label>
                        <textarea asp-for="Description" class="form-control" rows="5" placeholder="Opisz swoje doświadczenia z tym ogłoszeniem..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhotoFiles" class="form-label">Zdjęcia (maksymalnie 5)</label>
                        <div class="image-upload-container">
                            <input asp-for="PhotoFiles" type="file" multiple accept=".jpg,.jpeg,.png" class="form-control image-upload-input" />
                        </div>
                        <small class="form-hint">Możesz dołączyć zdjęcia do swojej opinii (maksymalnie 5 plików)</small>
                        <span asp-validation-for="PhotoFiles" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-controller="Listings" asp-action="Details" asp-route-slug="@SlugHelper.GenerateSlug(Model.ListingTitle)" asp-route-id="@Model.ListingId" class="btn btn-outline-secondary">Anuluj</a>
                        <button type="submit" class="btn btn-primary">Dodaj opinię</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
