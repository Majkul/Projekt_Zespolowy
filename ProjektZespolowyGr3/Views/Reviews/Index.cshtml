@model IEnumerable<ProjektZespolowyGr3.Models.DbModels.Review>

@{
    ViewData["Title"] = "Recenzje";
}

<div class="page-header mb-4">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title">Recenzje</h2>
        </div>
        <div class="col-auto ms-auto">
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Dodaj nową</a>
        </div>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-vcenter card-table">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Listing)</th>
                    <th>@Html.DisplayNameFor(model => model.Rating)</th>
                    <th>@Html.DisplayNameFor(model => model.Reviewer)</th>
                    <th>@Html.DisplayNameFor(model => model.Description)</th>
                    <th>@Html.DisplayNameFor(model => model.CreatedAt)</th>
                    <th>@Html.DisplayNameFor(model => model.Upvotes)</th>
                    <th>@Html.DisplayNameFor(model => model.Downvotes)</th>
                    <th class="w-1"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Listing.Id)</td>
                        <td>@Html.DisplayFor(modelItem => item.Rating)</td>
                        <td>@Html.DisplayFor(modelItem => item.Reviewer.Id)</td>
                        <td class="text-secondary text-truncate" style="max-width: 240px;">@Html.DisplayFor(modelItem => item.Description)</td>
                        <td class="text-secondary">@Html.DisplayFor(modelItem => item.CreatedAt)</td>
                        <td>@Html.DisplayFor(modelItem => item.Upvotes)</td>
                        <td>@Html.DisplayFor(modelItem => item.Downvotes)</td>
                        <td>
                            <div class="btn-list flex-nowrap">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edytuj</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Szczegóły</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Usuń</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
