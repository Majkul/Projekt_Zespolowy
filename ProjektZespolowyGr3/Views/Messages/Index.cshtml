@model IEnumerable<ProjektZespolowyGr3.Models.DbModels.Message>
@{
    ViewData["Title"] = "Wiadomości";
}
<div class="container mt-4">
    <h2 class="mb-4">Skrzynka odbiorcza</h2>
    <p class="text-muted">Lista rozmów, w których bierzesz udział.</p>
    @if (Model != null && Model.Any())
    {
        <div class="list-group">
            @foreach (var msg in Model)
            {
                var isListing = msg.ListingId.HasValue;
                var isTicket = msg.TicketId.HasValue;
                var otherUser = msg.SenderId == int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value)
                ? msg.Receiver
                : msg.Sender;
                <a class="list-group-item list-group-item-action @(msg.IsArchived ? "list-group-item-secondary" : "")"
                   asp-controller="Messages"
                   asp-action="Conversation"
                   asp-route-userId="@otherUser.Id"
                   asp-route-listingId="@(msg.ListingId)"
                   asp-route-ticketId="@(msg.TicketId)">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <h5 class="mb-1 @(msg.IsArchived ? "text-muted" : "")">
                            @otherUser.Username
                            @if (msg.IsArchived)
                            {
                                <span class="badge bg-secondary ms-2">Zarchiwizowana</span>
                            }
                        </h5>
                        <small class="text-muted">
                            @(msg.SentAt != DateTime.MinValue ? msg.SentAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "")
                        </small>
                    </div>
                    <p class="mb-1 text-truncate @(msg.IsArchived ? "text-muted fst-italic" : "")">
                        @if (msg.IsArchived)
                        {
                            <em>Wiadomość została usunięta.</em>
                        }
                        else
                        {
                            @msg.Content
                        }
                    </p>
                    <small class="text-muted">
                        @if (isListing && msg.Listing != null)
                        {
                            @:Ogłoszenie: @msg.Listing.Title
                        }
                        else if (isTicket && msg.Ticket != null)
                        {
                            @:Zgłoszenie: @msg.Ticket.Subject
                        }
                        else
                        {
                            @:Rozmowa ogólna
                        }
                    </small>
                </a>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Nie masz jeszcze żadnych rozmów.
        </div>
    }
</div>