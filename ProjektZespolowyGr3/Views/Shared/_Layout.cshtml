<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HandlujZTym</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjektZespolowyGr3.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">HandlujZTym</a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="navbar-collapse collapse d-lg-flex">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Listings" asp-action="Index">Oferty</a>
                        </li>
                    </ul>

                    <form class="d-flex mx-auto col-12 col-lg-5 mb-2 mb-lg-0" asp-controller="Listings" asp-action="Index" method="get">
                        <div class="input-group">
                            <input class="form-control" type="text" name="searchString" placeholder="Szukaj ofert..." aria-label="Szukaj ofert"/>
                            <button class="btn btn-outline-primary" type="submit">
                                <i class="bi bi-search"></i> Szukaj
                            </button>
                        </div>
                    </form>

                    <ul class="navbar-nav ms-auto align-items-center gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        Admin
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="adminDropdown">
                                        <li><a class="dropdown-item" asp-controller="UserManage" asp-action="Index">Użytkownicy</a></li>
                                        <li><a class="dropdown-item" asp-controller="ListingManage" asp-action="Index">Oferty</a></li>
                                        <li><a class="dropdown-item" asp-controller="TicketsManage" asp-action="Index">Zgłoszenia</a></li>
                                    </ul>
                                </li>
                            }

                            <li class="nav-item">
                                @await Component.InvokeAsync("UnreadNotifications")
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Messages" asp-action="Index" title="Wiadomości">
                                    <i class="bi bi-envelope fs-5"></i>
                                </a>
                            </li>
                        }

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark fw-bold d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <img src="/Images/Icons/user-icon.png" alt="User" class="rounded-circle me-2" width="24" height="24" />
                                    <span>Witaj, @User.Identity.Name!</span>
                                }
                                else
                                {
                                    <i class="bi bi-person-circle fs-5 me-2"></i>
                                    <span>Zaloguj się</span>
                                }
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <li><h6 class="dropdown-header">Tworzenie</h6></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Listings" asp-action="Create"><i class="bi bi-plus-circle me-2"></i>Stwórz ofertę</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Tickets" asp-action="Create"><i class="bi bi-ticket me-2"></i>Stwórz zgłoszenie</a></li>
                                    
                                    <li><hr class="dropdown-divider"/></li>
                                    <li><h6 class="dropdown-header">Moje konto</h6></li>
                                    <li><a class="dropdown-item" asp-controller="MyProfile" asp-action="Details">Mój profil</a></li>
                                    <li><a class="dropdown-item" asp-controller="ListingManage" asp-action="Index">Moje oferty</a></li>
                                    <li><a class="dropdown-item" asp-controller="TradeProposals" asp-action="Index">Moje wymiany</a></li>
                                    <li><a class="dropdown-item" asp-controller="Tickets" asp-action="Index">Moje zgłoszenia</a></li>
                                    <li><a class="dropdown-item" asp-controller="SellerCard" asp-action="Index"><i class="bi bi-credit-card me-2"></i>Karta płatnicza</a></li>

                                    <li><hr class="dropdown-divider"/></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button class="dropdown-item text-danger w-100 text-start" type="submit">
                                                <i class="bi bi-box-arrow-right me-2"></i>Wyloguj
                                            </button>
                                        </form>
                                    </li>
                                }
                                else
                                {
                                    <li><a class="dropdown-item fw-bold" asp-area="" asp-controller="Home" asp-action="Login">Zaloguj się</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Register">Zarejestruj się</a></li>
                                    <li><hr class="dropdown-divider"/></li>
                                    <li><span class="dropdown-item-text text-muted">Zaloguj się, aby tworzyć oferty i zgłoszenia.</span></li>
                                }
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 py-4">
        <div class="container text-center">
            &copy; 2025 - HandlujZTym - Wszystkie prawa zastrzeżone
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>