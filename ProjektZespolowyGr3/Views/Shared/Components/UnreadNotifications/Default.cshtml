@model int
<a class="nav-link px-0 position-relative" asp-controller="Notifications" asp-action="Index" title="Powiadomienia">
    <i class="bi bi-bell fs-3" aria-hidden="true"></i>
    @if (Model > 0)
    {
        <span class="badge bg-red text-white position-absolute top-0 start-100 translate-middle">@Model</span>
    }
</a>
