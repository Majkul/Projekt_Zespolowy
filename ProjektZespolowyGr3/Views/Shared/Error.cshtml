@model ErrorViewModel
@{
    ViewData["Title"] = "Błąd";
}

<div class="page-header mb-4">
    <h2 class="page-title text-danger">Wystąpił błąd</h2>
</div>

<div class="card">
    <div class="card-body">
        <p class="text-danger">Podczas przetwarzania żądania wystąpił błąd.</p>

        @if (Model.ShowRequestId)
        {
            <p class="mb-0">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </p>
        }
    </div>
</div>
