@model ProjektZespolowyGr3.Models.ViewModels.TradeProposalsIndexViewModel
@{
    ViewData["Title"] = "Moje wymiany";
    ViewBag.CurrentUserId = Model.CurrentUserId;
    ViewBag.ShowListingColumn = true;
}

<div class="page-header mb-4">
    <h2 class="page-title">Moje wymiany</h2>
</div>

@if (Model.ActiveOnePerListing.Count == 0 && Model.ArchivedOnePerListing.Count == 0)
{
    <div class="card card-md">
        <div class="card-body">
            <div class="empty">
                <div class="empty-icon"><i class="bi bi-arrow-left-right fs-1 text-secondary"></i></div>
                <p class="empty-title">Brak wymian</p>
                <p class="empty-subtitle text-secondary">Nie masz jeszcze żadnych propozycji wymiany.</p>
            </div>
        </div>
    </div>
}
else
{
    <p class="text-secondary small mb-4">
        Na liście jest <strong>jedna wymiana na ogłoszenie</strong>. Pełny wątek (kontroferty, historia) zobaczysz po wejściu w <strong>Szczegóły</strong>.
    </p>

    <section class="mb-5">
        <h3 class="h4 mb-3">Obecne wymiany</h3>
        @if (Model.ActiveOnePerListing.Count == 0)
        {
            <p class="text-secondary small mb-0">Brak trwających negocjacji.</p>
        }
        else
        {
            await Html.RenderPartialAsync("_TradeProposalsProposalTable", Model.ActiveOnePerListing);
        }
    </section>

    <section>
        <h3 class="h4 mb-3">Zarchiwizowane wymiany</h3>
        @if (Model.ArchivedOnePerListing.Count == 0)
        {
            <p class="text-secondary small mb-0">Brak zarchiwizowanych wymian (lub masz nadal otwartą negocjację przy danym ogłoszeniu).</p>
        }
        else
        {
            await Html.RenderPartialAsync("_TradeProposalsProposalTable", Model.ArchivedOnePerListing);
        }
    </section>
}
