@model ProjektZespolowyGr3.Models.ViewModels.ComposeTradeViewModel
@using ProjektZespolowyGr3.Models.DbModels
@using System.Globalization
@{
    ViewData["Title"] = "Propozycja wymiany";
    var subject = Model.SubjectListing;
}

<div class="container mt-4 mb-5">
    <h2 class="mb-1">@(Model.ParentTradeProposalId.HasValue ? "Kontroferta" : "Propozycja wymiany")</h2>
    <p class="text-muted mb-3">Ogłoszenie: <strong>@subject.Title</strong></p>

    @if (!subject.NotExchangeable && (subject.MinExchangeValue.HasValue || (subject.ExchangeAcceptedTags != null && subject.ExchangeAcceptedTags.Any()) || !string.IsNullOrWhiteSpace(subject.ExchangeDescription)))
    {
        <div class="card mb-3 border-warning">
            <div class="card-header bg-warning bg-opacity-25 small fw-semibold">Warunki wymiany sprzedającego</div>
            <div class="card-body small">
                @if (subject.MinExchangeValue.HasValue)
                {
                    var buyerLogin = Model.BuyerOffersFromInitiatorColumn ? Model.InitiatorUsername : Model.ReceiverUsername;
                    <p class="mb-2"><strong>Minimalna wartość po stronie kupującego (@buyerLogin):</strong> @subject.MinExchangeValue.Value.ToString("C")</p>
                }
                @if (subject.ExchangeAcceptedTags != null && subject.ExchangeAcceptedTags.Any())
                {
                    <p class="mb-2"><strong>Akceptowane tagi:</strong> @string.Join(", ", subject.ExchangeAcceptedTags.Select(e => e.Tag.Name))</p>
                }
                @if (!string.IsNullOrWhiteSpace(subject.ExchangeDescription))
                {
                    <p class="mb-0"><strong>Czego szuka sprzedający:</strong> @subject.ExchangeDescription</p>
                }
            </div>
        </div>
    }

    @if (Model.ParentProposal != null)
    {
        @await Html.PartialAsync("_ParentProposalPreview", Model)
    }

    @if (TempData["TradeError"] != null)
    {
        <div class="alert alert-danger">@TempData["TradeError"]</div>
    }

    <form asp-controller="TradeProposals" asp-action="Create" method="post" class="row g-4" id="trade-compose-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="subjectListingId" value="@Model.SubjectListingId" />
        @if (Model.EditTradeProposalId.HasValue)
        {
            <input type="hidden" name="editTradeProposalId" value="@Model.EditTradeProposalId" />
        }
        @if (Model.ParentTradeProposalId.HasValue)
        {
            <input type="hidden" name="parentTradeProposalId" value="@Model.ParentTradeProposalId" />
        }

        <div class="col-md-6">
            <div class="card h-100 border-primary">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <span>Składający — <strong>@Model.InitiatorUsername</strong></span>
                    <span class="fw-normal small">Wartość: <span id="sum-initiator">—</span></span>
                </div>
                <div class="card-body">
                    @foreach (var l in Model.InitiatorPool)
                    {
                        var priceStr = (l.Price ?? 0).ToString(CultureInfo.InvariantCulture);
                        var qtyVal = Model.InitiatorQuantities.TryGetValue(l.Id, out var iq) ? iq : 1;
                        <div class="trade-line border rounded px-2 py-2 mb-2 d-flex flex-wrap align-items-center gap-2" data-side="initiator">
                            <input class="form-check-input flex-shrink-0" type="checkbox" name="initiatorListingIds" value="@l.Id" id="i_@l.Id"
                                   data-listing-price="@priceStr"
                                   checked="@(Model.SelectedInitiatorListingIds.Contains(l.Id))" />
                            <label class="form-check-label flex-grow-1 mb-0" for="i_@l.Id">@l.Title (@(l.Price?.ToString("C") ?? "bez ceny"))@(l.StockQuantity > 1 ? $" · {l.StockQuantity} szt." : "")</label>
                            @{
                                var img = l.Photos?.FirstOrDefault(p => p.IsFeatured)?.Upload?.Url ?? l.Photos?.FirstOrDefault()?.Upload?.Url;
                            }
                            @if (!string.IsNullOrEmpty(img))
                            {
                                <img src="@img" alt="" class="rounded flex-shrink-0" style="width:40px;height:40px;object-fit:cover;" />
                            }
                            @if (l.StockQuantity > 1)
                            {
                                <div class="d-flex align-items-center gap-1 ms-auto">
                                    <label class="small text-muted mb-0" for="iq_@l.Id">Szt.</label>
                                    <input type="number" name="initiatorQuantities[@l.Id]" id="iq_@l.Id" class="form-control form-control-sm trade-qty" min="1" max="@l.StockQuantity" value="@qtyVal" style="width:4.5rem;" />
                                </div>
                            }
                            else
                            {
                                <input type="hidden" name="initiatorQuantities[@l.Id]" value="1" />
                            }
                        </div>
                    }
                    @if (!Model.InitiatorPool.Any())
                    {
                        <p class="text-muted small">Brak ogłoszeń dostępnych do wymiany.</p>
                    }
                    <div class="mt-2 mb-1">
                        <a href="@Url.Action("Create", "Listings", new { forTradeListingId = Model.SubjectListingId })"
                           class="btn btn-sm btn-outline-primary">
                            + Utwórz nowe ogłoszenie pod tę wymianę
                        </a>
                    </div>
                    <hr />
                    <label class="form-label" for="initiatorCash">Dopłata gotówką (PLN)</label>
                    <input type="number" name="initiatorCash" id="initiatorCash" class="form-control" step="0.01" min="0" value="@Model.InitiatorCash.ToString(CultureInfo.InvariantCulture)" />
                    <hr class="mt-3" />
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <small class="fw-semibold text-muted">Przedmioty spoza systemu (opcjonalnie)</small>
                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="addCustomItem('initiator')">+ Dodaj przedmiot</button>
                    </div>
                    <div id="initiator-custom-items">
                        @for (int ci = 0; ci < Model.InitiatorCustomItems.Count; ci++)
                        {
                            var item = Model.InitiatorCustomItems[ci];
                            <div class="custom-item-row border rounded px-2 py-2 mb-2" data-side="initiator">
                                <div class="row g-2 align-items-center">
                                    <div class="col-6">
                                        <input type="text" name="initiatorCustomTitles[@ci]" value="@item.Title" class="form-control form-control-sm" placeholder="Nazwa przedmiotu" />
                                    </div>
                                    <div class="col-4">
                                        <div class="input-group input-group-sm">
                                            <input type="number" name="initiatorCustomValues[@ci]" value="@item.EstimatedValue.ToString(CultureInfo.InvariantCulture)" step="0.01" min="0" class="form-control custom-item-value" placeholder="0.00" data-side="initiator" />
                                            <span class="input-group-text">PLN</span>
                                        </div>
                                    </div>
                                    <div class="col-2">
                                        <button type="button" class="btn btn-outline-danger btn-sm w-100" onclick="removeCustomItem(this)">✕</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 border-secondary">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Otrzymujący — <strong>@Model.ReceiverUsername</strong></span>
                    <span class="fw-normal small text-muted">Wartość: <span id="sum-receiver">—</span></span>
                </div>
                <div class="card-body">
                    @foreach (var l in Model.ReceiverPool)
                    {
                        var priceStr = (l.Price ?? 0).ToString(CultureInfo.InvariantCulture);
                        var qtyVal = Model.ReceiverQuantities.TryGetValue(l.Id, out var rq) ? rq : 1;
                        <div class="trade-line border rounded px-2 py-2 mb-2 d-flex flex-wrap align-items-center gap-2" data-side="receiver">
                            <input class="form-check-input flex-shrink-0" type="checkbox" name="receiverListingIds" value="@l.Id" id="r_@l.Id"
                                   data-listing-price="@priceStr"
                                   checked="@(Model.SelectedReceiverListingIds.Contains(l.Id))" />
                            <label class="form-check-label flex-grow-1 mb-0" for="r_@l.Id">@l.Title (@(l.Price?.ToString("C") ?? "bez ceny"))@(l.StockQuantity > 1 ? $" · {l.StockQuantity} szt." : "")</label>
                            @{
                                var img = l.Photos?.FirstOrDefault(p => p.IsFeatured)?.Upload?.Url ?? l.Photos?.FirstOrDefault()?.Upload?.Url;
                            }
                            @if (!string.IsNullOrEmpty(img))
                            {
                                <img src="@img" alt="" class="rounded flex-shrink-0" style="width:40px;height:40px;object-fit:cover;" />
                            }
                            @if (l.StockQuantity > 1)
                            {
                                <div class="d-flex align-items-center gap-1 ms-auto">
                                    <label class="small text-muted mb-0" for="rq_@l.Id">Szt.</label>
                                    <input type="number" name="receiverQuantities[@l.Id]" id="rq_@l.Id" class="form-control form-control-sm trade-qty" min="1" max="@l.StockQuantity" value="@qtyVal" style="width:4.5rem;" />
                                </div>
                            }
                            else
                            {
                                <input type="hidden" name="receiverQuantities[@l.Id]" value="1" />
                            }
                        </div>
                    }
                    <hr />
                    <label class="form-label" for="receiverCash">Dopłata gotówką po stronie odbiorcy (PLN)</label>
                    <input type="number" name="receiverCash" id="receiverCash" class="form-control" step="0.01" min="0" value="@Model.ReceiverCash.ToString(CultureInfo.InvariantCulture)" />
                    <hr class="mt-3" />
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <small class="fw-semibold text-muted">Przedmioty spoza systemu (opcjonalnie)</small>
                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="addCustomItem('receiver')">+ Dodaj przedmiot</button>
                    </div>
                    <div id="receiver-custom-items">
                        @for (int ri = 0; ri < Model.ReceiverCustomItems.Count; ri++)
                        {
                            var ritem = Model.ReceiverCustomItems[ri];
                            <div class="custom-item-row border rounded px-2 py-2 mb-2" data-side="receiver">
                                <div class="row g-2 align-items-center">
                                    <div class="col-6">
                                        <input type="text" name="receiverCustomTitles[@ri]" value="@ritem.Title" class="form-control form-control-sm" placeholder="Nazwa przedmiotu" />
                                    </div>
                                    <div class="col-4">
                                        <div class="input-group input-group-sm">
                                            <input type="number" name="receiverCustomValues[@ri]" value="@ritem.EstimatedValue.ToString(CultureInfo.InvariantCulture)" step="0.01" min="0" class="form-control custom-item-value" placeholder="0.00" data-side="receiver" />
                                            <span class="input-group-text">PLN</span>
                                        </div>
                                    </div>
                                    <div class="col-2">
                                        <button type="button" class="btn btn-outline-danger btn-sm w-100" onclick="removeCustomItem(this)">✕</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (subject.MinExchangeValue.HasValue)
        {
            <div class="col-12" id="buyer-min-wrap">
                <div id="buyer-min-hint" class="alert small py-2 mb-0"></div>
            </div>
        }

        <div class="col-12">
            <button type="submit" class="btn btn-primary btn-lg">@(Model.EditTradeProposalId.HasValue ? "Zapisz zmiany" : Model.ParentTradeProposalId.HasValue ? "Wyślij kontrofertę" : "Wyślij propozycję")</button>
            <a asp-controller="Listings" asp-action="Details" asp-route-id="@Model.SubjectListingId" class="btn btn-outline-secondary">Anuluj</a>
        </div>
    </form>
</div>

