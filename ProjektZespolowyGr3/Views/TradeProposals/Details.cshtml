@model ProjektZespolowyGr3.Models.DbModels.TradeProposal
@using ProjektZespolowyGr3.Models.DbModels
@using System.Reflection
@using System.ComponentModel.DataAnnotations
@{
    ViewData["Title"] = "Propozycja wymiany";
    var initiatorSum = (decimal)(ViewBag.InitiatorSum ?? 0m);
    var receiverSum = (decimal)(ViewBag.ReceiverSum ?? 0m);
    var thread = ViewBag.Thread as List<TradeProposal> ?? new List<TradeProposal>();
    var cu = ViewBag.CurrentUserId is int cid ? cid : 0;
    var tradeOrders = ViewBag.TradeOrders as List<TradeOrder> ?? new List<TradeOrder>();

    string StatusName(TradeProposalStatus s)
    {
        var m = typeof(TradeProposalStatus).GetMember(s.ToString());
        if (m.Length > 0 && m[0].GetCustomAttribute<DisplayAttribute>() is { } d && !string.IsNullOrEmpty(d.Name))
            return d.Name!;
        return s.ToString();
    }
}

<div class="container mt-4 mb-5">
    <h2 class="mb-1">Propozycja wymiany</h2>
    <p class="text-muted mb-2">
        Identyfikator referencyjny <strong>#@Model.Id</strong>
        @if (Model.SubjectListing != null)
        {
            <span> · Ogłoszenie: <strong>@Model.SubjectListing.Title</strong></span>
        }
    </p>
    <p class="text-muted">
        Status: <strong>@StatusName(Model.Status)</strong>
        · Ostatnia modyfikacja: @Model.LastModifiedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
    </p>
    <p class="small text-muted border-start border-3 ps-2 mb-3">
        <strong>Otrzymujący Ofertę</strong> — osoba, której skierowano propozycję (może ją zaakceptować, odrzucić lub złożyć kontrofertę).
        <strong>Składający Ofertę</strong> — osoba, która wysłała tę propozycję. Te role są stałe dla danej propozycji.
    </p>

    @if (thread.Count > 0)
    {
        <div class="alert alert-light border mb-3">
            <strong>Wątek kontrofert</strong>
            <span class="text-muted">(od najstarszej do najnowszej)</span>
            @if (thread.Count == 1)
            {
                <p class="small text-muted mt-2 mb-0">Na razie jest jeden krok — kolejne propozycje pojawią się tutaj po złożeniu kontroferty.</p>
            }
            <ol class="mb-0 mt-2 ps-3">
                @for (var k = 0; k < thread.Count; k++)
                {
                    var t = thread[k];
                    var isCurrent = t.Id == Model.Id;
                    <li class="mb-1">
                        <a asp-action="Details" asp-route-id="@t.Id">Krok @(k + 1): @t.Initiator.Username składa propozycję dla @t.Receiver.Username</a>
                        — @StatusName(t.Status)
                        @if (isCurrent)
                        {
                            <span class="badge bg-primary ms-1">przeglądasz</span>
                        }
                    </li>
                }
            </ol>
        </div>
    }

    @if (Model.ParentTradeProposal != null)
    {
        var parent = Model.ParentTradeProposal;
        var pInit = (decimal)(ViewBag.ParentInitiatorSum ?? 0m);
        var pRecv = (decimal)(ViewBag.ParentReceiverSum ?? 0m);

        <div class="mb-4">
            <h5 class="mb-2">Poprzednia kontroferta</h5>
            <p class="text-muted small mb-3">
                Ref. <strong>#@parent.Id</strong> · @StatusName(parent.Status)
                · <a asp-action="Details" asp-route-id="@parent.Id">Otwórz w osobnym widoku</a>
            </p>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card border-secondary">
                        <div class="card-header bg-secondary text-white">Otrzymujący Ofertę — @parent.Receiver.Username</div>
                        <div class="card-body">
                            <p class="mb-2">Szacowana wartość: <strong>@pRecv.ToString("C")</strong></p>
                            @foreach (var it in parent.Items.Where(i => i.Side == TradeProposalSide.Receiver).OrderBy(i => i.Id))
                            {
                                if (it.Listing != null)
                                {
                                    ViewBag.ProposedTradeQuantity = Math.Max(1, it.Quantity);
                                    @await Html.PartialAsync("_TradeListingPreview", it.Listing)
                                    ViewBag.ProposedTradeQuantity = null;
                                }
                                if (it.CashAmount.HasValue)
                                {
                                    <div class="border rounded p-2 mb-2 bg-light small">
                                        Dopłata gotówką: <strong>@it.CashAmount.Value.ToString("C")</strong>
                                    </div>
                                }
                                if (it.CustomOfferTitle != null)
                                {
                                    <div class="border rounded p-2 mb-2 bg-light small d-flex justify-content-between align-items-center">
                                        <span>📦 <strong>@it.CustomOfferTitle</strong></span>
                                        @if (it.CustomOfferEstimatedValue.HasValue)
                                        {
                                            <span class="text-muted ms-2">est. @it.CustomOfferEstimatedValue.Value.ToString("C")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted ms-2">bez wyceny</span>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-primary">
                        <div class="card-header bg-primary text-white">Składający Ofertę — @parent.Initiator.Username</div>
                        <div class="card-body">
                            <p class="mb-2">Szacowana wartość: <strong>@pInit.ToString("C")</strong></p>
                            @foreach (var it in parent.Items.Where(i => i.Side == TradeProposalSide.Initiator).OrderBy(i => i.Id))
                            {
                                if (it.Listing != null)
                                {
                                    ViewBag.ProposedTradeQuantity = Math.Max(1, it.Quantity);
                                    @await Html.PartialAsync("_TradeListingPreview", it.Listing)
                                    ViewBag.ProposedTradeQuantity = null;
                                }
                                if (it.CashAmount.HasValue)
                                {
                                    <div class="border rounded p-2 mb-2 bg-light small">
                                        Dopłata gotówką: <strong>@it.CashAmount.Value.ToString("C")</strong>
                                    </div>
                                }
                                if (it.CustomOfferTitle != null)
                                {
                                    <div class="border rounded p-2 mb-2 bg-light small d-flex justify-content-between align-items-center">
                                        <span>📦 <strong>@it.CustomOfferTitle</strong></span>
                                        @if (it.CustomOfferEstimatedValue.HasValue)
                                        {
                                            <span class="text-muted ms-2">est. @it.CustomOfferEstimatedValue.Value.ToString("C")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted ms-2">bez wyceny</span>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <hr class="my-4" />
        <h5 class="mb-3">Obecna propozycja</h5>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card border-secondary">
                <div class="card-header bg-secondary text-white">Otrzymujący Ofertę — @Model.Receiver.Username</div>
                <div class="card-body">
                    <p class="mb-2">Szacowana wartość: <strong>@receiverSum.ToString("C")</strong></p>
                    @foreach (var it in Model.Items.Where(i => i.Side == TradeProposalSide.Receiver).OrderBy(i => i.Id))
                    {
                        if (it.Listing != null)
                        {
                            ViewBag.ProposedTradeQuantity = Math.Max(1, it.Quantity);
                            @await Html.PartialAsync("_TradeListingPreview", it.Listing)
                            ViewBag.ProposedTradeQuantity = null;
                        }
                        if (it.CashAmount.HasValue)
                        {
                            <div class="border rounded p-2 mb-2 bg-light small">
                                Dopłata gotówką: <strong>@it.CashAmount.Value.ToString("C")</strong>
                            </div>
                        }
                        if (it.CustomOfferTitle != null)
                        {
                            <div class="border rounded p-2 mb-2 bg-light small d-flex justify-content-between align-items-center">
                                <span>📦 <strong>@it.CustomOfferTitle</strong></span>
                                @if (it.CustomOfferEstimatedValue.HasValue)
                                {
                                    <span class="text-muted ms-2">est. @it.CustomOfferEstimatedValue.Value.ToString("C")</span>
                                }
                                else
                                {
                                    <span class="text-muted ms-2">bez wyceny</span>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-primary">
                <div class="card-header bg-primary text-white">Składający Ofertę — @Model.Initiator.Username</div>
                <div class="card-body">
                    <p class="mb-2">Szacowana wartość: <strong>@initiatorSum.ToString("C")</strong></p>
                    @foreach (var it in Model.Items.Where(i => i.Side == TradeProposalSide.Initiator).OrderBy(i => i.Id))
                    {
                        if (it.Listing != null)
                        {
                            ViewBag.ProposedTradeQuantity = Math.Max(1, it.Quantity);
                            @await Html.PartialAsync("_TradeListingPreview", it.Listing)
                            ViewBag.ProposedTradeQuantity = null;
                        }
                        if (it.CashAmount.HasValue)
                        {
                            <div class="border rounded p-2 mb-2 bg-light small">
                                Dopłata gotówką: <strong>@it.CashAmount.Value.ToString("C")</strong>
                            </div>
                        }
                        if (it.CustomOfferTitle != null)
                        {
                            <div class="border rounded p-2 mb-2 bg-light small d-flex justify-content-between align-items-center">
                                <span>📦 <strong>@it.CustomOfferTitle</strong></span>
                                @if (it.CustomOfferEstimatedValue.HasValue)
                                {
                                    <span class="text-muted ms-2">est. @it.CustomOfferEstimatedValue.Value.ToString("C")</span>
                                }
                                else
                                {
                                    <span class="text-muted ms-2">bez wyceny</span>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    @if (TempData["TradeSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["TradeSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["TradeInfo"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @TempData["TradeInfo"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["TradeError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["TradeError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Status == TradeProposalStatus.Pending)
    {
        var isReceiver = cu == Model.ReceiverUserId;
        var isInitiator = cu == Model.InitiatorUserId;

        <div class="card mb-4 border-warning">
            <div class="card-header bg-warning bg-opacity-10 fw-bold">⏳ Propozycja oczekuje na odpowiedź</div>
            <div class="card-body">

                @if (isReceiver)
                {
                    <p class="text-muted small mb-3">
                        To Ty jesteś odbiorcą tej propozycji. Możesz ją zaakceptować, odrzucić lub złożyć kontrofertę.
                    </p>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <form asp-action="Accept" asp-route-id="@Model.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-success"
                                    onclick="return confirm('Czy na pewno chcesz zaakceptować tę propozycję wymiany?')">
                                ✅ Zaakceptuj
                            </button>
                        </form>
                        <form asp-action="Reject" asp-route-id="@Model.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-danger"
                                    onclick="return confirm('Czy na pewno chcesz odrzucić tę propozycję?')">
                                ✖ Odrzuć
                            </button>
                        </form>
                        <a asp-action="Compose"
                           asp-route-listingId="@Model.SubjectListingId"
                           asp-route-parentTradeProposalId="@Model.Id"
                           class="btn btn-outline-primary">
                            🔄 Pełna kontroferta
                        </a>
                        <button type="button" class="btn btn-outline-secondary"
                                data-bs-toggle="collapse" data-bs-target="#quick-bargain-panel">
                            💬 Szybkie targowanie
                        </button>
                    </div>

                    var curInitCash = Model.Items.Where(i => i.Side == TradeProposalSide.Initiator && i.CashAmount.HasValue).Sum(i => i.CashAmount!.Value);
                    var curRecvCash = Model.Items.Where(i => i.Side == TradeProposalSide.Receiver && i.CashAmount.HasValue).Sum(i => i.CashAmount!.Value);

                    <div class="collapse" id="quick-bargain-panel">
                        <div class="card card-body bg-light border-primary mt-2">
                            <h6 class="mb-3">💬 Szybkie targowanie — zmień kwoty dopłat gotówkowych</h6>
                            <p class="text-muted small mb-3">
                                Przedmioty pozostają bez zmian. Możesz zaproponować inne kwoty dopłat.
                                Aktualne: <strong>@Model.Initiator.Username dopłaca @curInitCash.ToString("C")</strong>,
                                <strong>@Model.Receiver.Username dopłaca @curRecvCash.ToString("C")</strong>.
                            </p>
                            <form asp-action="QuickCounterOffer" asp-route-id="@Model.Id" method="post">
                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Dopłata od <strong>@Model.Initiator.Username</strong> (PLN)</label>
                                        <div class="input-group">
                                            <input type="number" name="initiatorCash" step="0.01" min="0"
                                                   value="@curInitCash.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                                   class="form-control" placeholder="0.00" />
                                            <span class="input-group-text">PLN</span>
                                        </div>
                                        <small class="text-muted">Kwota, którą @Model.Initiator.Username dopłaca do wymiany</small>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Dopłata od <strong>@Model.Receiver.Username</strong> (PLN)</label>
                                        <div class="input-group">
                                            <input type="number" name="receiverCash" step="0.01" min="0"
                                                   value="@curRecvCash.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                                   class="form-control" placeholder="0.00" />
                                            <span class="input-group-text">PLN</span>
                                        </div>
                                        <small class="text-muted">Kwota, którą @Model.Receiver.Username dopłaca do wymiany</small>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Wiadomość (opcjonalnie)</label>
                                    <textarea name="message" class="form-control" rows="2"
                                              placeholder="Np. Proponuję zmianę dopłaty, bo…"></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    📨 Wyślij kontrofertę
                                </button>
                            </form>
                        </div>
                    </div>
                }

                @if (isInitiator)
                {
                    <p class="text-muted small mb-3">
                        Propozycja oczekuje na odpowiedź od <strong>@Model.Receiver.Username</strong>.
                        Możesz ją anulować lub edytować.
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-outline-danger"
                                    onclick="return confirm('Czy na pewno chcesz anulować tę propozycję?')">
                                ✖ Anuluj propozycję
                            </button>
                        </form>
                        <a asp-action="Compose"
                           asp-route-listingId="@Model.SubjectListingId"
                           asp-route-editTradeProposalId="@Model.Id"
                           class="btn btn-outline-secondary">
                            ✏️ Edytuj propozycję
                        </a>
                    </div>
                }

            </div>
        </div>
    }

    @if (Model.History != null && Model.History.Any())
    {
        <details class="mb-4">
            <summary class="fw-bold text-muted small" style="cursor:pointer;">Historia zmian (@Model.History.Count())</summary>
            <ul class="small mt-2">
                @foreach (var h in Model.History.OrderByDescending(x => x.ChangedAt))
                {
                    <li>@h.ChangedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm") — @h.User.Username: @h.Summary</li>
                }
            </ul>
        </details>
    }

    @if (Model.Status == TradeProposalStatus.Accepted)
    {
        var myPayerSide = cu == Model.InitiatorUserId ? TradeProposalSide.Initiator : TradeProposalSide.Receiver;
        var myItems = Model.Items.Where(i => i.Side == myPayerSide).ToList();
        var myCash = myItems.Where(i => i.CashAmount.HasValue).Sum(i => i.CashAmount!.Value);
        var myShippingOptions = myItems
            .Where(i => i.Listing != null)
            .SelectMany(i => i.Listing!.ShippingOptions)
            .ToList();
        var myOrder = tradeOrders.FirstOrDefault(o => o.PayerSide == myPayerSide);
        bool myPaid = myOrder?.Status == OrderStatus.Paid;
        bool hasSomethingToPay = myCash > 0 || myShippingOptions.Any();

        @if (TempData["TradePaymentError"] != null)
        {
            <div class="alert alert-warning mt-3">@TempData["TradePaymentError"]</div>
        }
        @if (TempData["TradePaymentInfo"] != null)
        {
            <div class="alert alert-info mt-3">@TempData["TradePaymentInfo"]</div>
        }

        @if (hasSomethingToPay)
        {
            <div class="card mt-4 border-success">
                <div class="card-header bg-success bg-opacity-10 fw-bold">
                    💳 Twoja płatność za wymianę
                </div>
                <div class="card-body">
                    @if (myPaid)
                    {
                        <div class="alert alert-success mb-0">
                            ✅ Płatność zrealizowana!
                            @if (myOrder!.SelectedShippingName != null)
                            {
                                <span class="text-muted small ms-2">Dostawa: @myOrder.SelectedShippingName</span>
                            }
                        </div>
                    }
                    else
                    {
                        <form asp-controller="Payment" asp-action="BuyTradeOrder" method="post">
                            <input type="hidden" name="tradeId" value="@Model.Id" />

                            @if (myCash > 0)
                            {
                                <div class="mb-3">
                                    <strong>Dopłata gotówkowa:</strong>
                                    <span class="text-primary fs-5 ms-2">@myCash.ToString("C")</span>
                                    <div class="form-text">Kwota wynikająca z warunków uzgodnionych w propozycji wymiany.</div>
                                </div>
                            }

                            @if (myShippingOptions.Any())
                            {
                                <div class="mb-3">
                                    <label class="form-label fw-bold">🚚 Wybierz metodę dostawy Twoich przedmiotów</label>
                                    @foreach (var opt in myShippingOptions)
                                    {
                                        <div class="form-check">
                                            <input class="form-check-input trade-ship-radio"
                                                   type="radio"
                                                   name="shippingOptionId"
                                                   id="tship-@opt.Id"
                                                   value="@opt.Id"
                                                   data-price="@opt.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                                   required />
                                            <label class="form-check-label" for="tship-@opt.Id">
                                                @opt.Name
                                                @if (opt.Price == 0)
                                                {
                                                    <span class="badge bg-success ms-1">Gratis</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">— @opt.Price.ToString("C")</span>
                                                }
                                            </label>
                                        </div>
                                    }
                                </div>
                            }

                            @if (myCash > 0 || myShippingOptions.Any())
                            {
                                <div class="alert alert-light border py-2 mb-3" id="trade-price-summary">
                                    @if (myCash > 0)
                                    {
                                        <div class="d-flex justify-content-between">
                                            <span class="text-muted small">Dopłata</span>
                                            <span class="small">@myCash.ToString("C")</span>
                                        </div>
                                    }
                                    @if (myShippingOptions.Any())
                                    {
                                        <div class="d-flex justify-content-between">
                                            <span class="text-muted small">Dostawa</span>
                                            <span class="small" id="tship-cost-display">—</span>
                                        </div>
                                    }
                                    <hr class="my-1" />
                                    <div class="d-flex justify-content-between fw-bold">
                                        <span>Razem</span>
                                        <span id="ttrade-total">@(myShippingOptions.Any() ? "—" : myCash.ToString("C"))</span>
                                    </div>
                                </div>
                            }

                            <button type="submit" class="btn btn-success">
                                💳 Zapłać przez PayU
                            </button>
                        </form>

                        @if (myShippingOptions.Any())
                        {
                            <script>
                                const tradeCash = @myCash.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                                const fmtPLN = v => v.toLocaleString('pl-PL', { style: 'currency', currency: 'PLN' });
                                document.querySelectorAll('.trade-ship-radio').forEach(r => {
                                    r.addEventListener('change', () => {
                                        const ship = parseFloat(r.dataset.price);
                                        document.getElementById('tship-cost-display').textContent =
                                            ship === 0 ? 'Gratis' : fmtPLN(ship);
                                        document.getElementById('ttrade-total').textContent =
                                            fmtPLN(tradeCash + ship);
                                    });
                                });
                            </script>
                        }
                    }
                </div>
            </div>
        }
    }

    @{
        var other = cu == Model.InitiatorUserId ? Model.ReceiverUserId : Model.InitiatorUserId;
    }
    <div class="d-flex flex-wrap gap-2 align-items-center mt-3">
        <a asp-controller="Messages" asp-action="Conversation" asp-route-userId="@other" asp-route-listingId="@Model.SubjectListingId" class="btn btn-outline-primary">Wróć do rozmowy</a>

        @if (Model.Status == TradeProposalStatus.Accepted)
        {
            <a asp-controller="ShippingLabel" asp-action="Trade" asp-route-tradeId="@Model.Id"
               class="btn btn-primary" target="_blank">
                🖨️ Generuj etykiety wysyłkowe
            </a>
        }
    </div>
</div>
