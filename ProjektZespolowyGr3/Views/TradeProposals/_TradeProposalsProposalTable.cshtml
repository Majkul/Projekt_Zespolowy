@model IReadOnlyList<ProjektZespolowyGr3.Models.DbModels.TradeProposal>
@using ProjektZespolowyGr3.Models.DbModels
@{
    var userId = (int)ViewBag.CurrentUserId;
    var showListing = ViewBag.ShowListingColumn as bool? == true;

    string StatusLabel(TradeProposalStatus s) => s switch
    {
        TradeProposalStatus.Pending => "Oczekuje",
        TradeProposalStatus.Accepted => "Zaakceptowana",
        TradeProposalStatus.Rejected => "Odrzucona",
        TradeProposalStatus.Cancelled => "Anulowana",
        TradeProposalStatus.Superseded => "Zastąpiona",
        _ => s.ToString()
    };

    string StatusBadge(TradeProposalStatus s) => s switch
    {
        TradeProposalStatus.Pending => "bg-yellow-lt",
        TradeProposalStatus.Accepted => "bg-green-lt",
        TradeProposalStatus.Rejected => "bg-red-lt",
        TradeProposalStatus.Cancelled => "bg-secondary-lt",
        TradeProposalStatus.Superseded => "bg-secondary-lt",
        _ => "bg-secondary-lt"
    };
}
@if (Model.Count > 0)
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-vcenter card-table mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        @if (showListing)
                        {
                            <th>Ogłoszenie</th>
                        }
                        <th>Druga strona</th>
                        <th>Rola</th>
                        <th>Status</th>
                        <th>Ostatnia zmiana</th>
                        <th class="w-1 text-end">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        var counterpart = p.InitiatorUserId == userId ? p.Receiver : p.Initiator;
                        var role = p.InitiatorUserId == userId ? "Składasz ofertę" : "Otrzymujesz ofertę";
                        <tr>
                            <td class="text-secondary">@p.Id</td>
                            @if (showListing)
                            {
                                <td>
                                    @(p.SubjectListing?.Title ?? "-")
                                    @if (p.SubjectListingId > 0)
                                    {
                                        <a class="d-block small" asp-controller="Listings" asp-action="Details" asp-route-slug="@SlugHelper.GenerateSlug(p.SubjectListing?.Title ?? "ogloszenie")" asp-route-id="@p.SubjectListingId">Ogłoszenie</a>
                                    }
                                </td>
                            }
                            <td>@counterpart.Username</td>
                            <td class="text-secondary">@role</td>
                            <td><span class="badge @StatusBadge(p.Status)">@StatusLabel(p.Status)</span></td>
                            <td class="text-secondary">@p.LastModifiedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@p.Id">Szczegóły</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
