@model List<ProjektZespolowyGr3.Models.ViewModels.BrowseListingsViewModel>

@{
    bool showArchived = ViewBag.ShowArchived ?? false;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">@(showArchived ? "Archiwalne oferty" : "Aktywne oferty")</h2>
    <a asp-action="Index" asp-route-showArchived="@(!showArchived)"
       class="btn @(showArchived ? "btn-outline-primary" : "btn-outline-secondary")">
        @(showArchived ? "Pokaż aktywne" : "Pokaż archiwalne")
    </a>
</div>

<form asp-action="Index" method="get" class="form-inline d-flex justify-content-between align-items-center mb-4 w-100">

    <input type="hidden" name="showArchived" value="@showArchived.ToString().ToLower()" />

    <div class="d-flex align-items-center flex-wrap gap-2 flex-grow-1">
        <input type="text"
               name="searchString"
               class="form-control"
               placeholder="Search user..."
               value="@ViewBag.CurrentFilter"
               style="min-width: 250px;" />

        <button type="submit" class="btn btn-primary">Search</button>

        <label for="pageSize" class="mb-0 ms-3 me-2 small text-muted">Show limit:</label>
        <select id="pageSize"
                name="pageSize"
                class="form-select form-select-sm"
                style="width: 80px;"
                onchange="this.form.submit()">
            @{
                int currentPageSize = ViewBag.CurrentPageSize ?? 25;
                int[] sizes = new[] { 25, 50, 100, 500, 1000 };
            }
            @foreach (var size in sizes)
            {
                if (size == currentPageSize)
                {
                    <option value="@size" selected="selected">@size</option>
                }
                else
                {
                    <option value="@size">@size</option>
                }
            }
        </select>
        <label for="tagFilter" class="mb-0 ms-3 me-2 small text-muted">Filter by tag:</label>
        <select id="tagFilter"
                name="tagFilter"
                class="form-select form-select-sm"
                style="width: 140px;"
                onchange="this.form.submit()">
            @{
                string currentTag = ViewBag.CurrentTag as string ?? "";
                string[] tags = new[] { "", "Books", "Electronics"}; @*Dwa testowe potem dodać żeby automatycznie z bazy brało *@
            }
            @foreach (var tag in tags)
            {
                var label = string.IsNullOrEmpty(tag) ? "-- All --" : tag;
                if (tag == currentTag)
                {
                    <option value="@tag" selected="selected">@label</option>
                }
                else
                {
                    <option value="@tag">@label</option>
                }
            }
        </select>
    </div>
</form>


<table class="table table-striped table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th scope="col">Tytuł</th>
            <th scope="col">Opis</th>
            <th scope="col">Sprzedający</th>
            <th scope="col">Oceny</th>
            <th scope="col">Cena</th>
            <th scope="col" style="width: 160px;">Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <a asp-controller="Listings" asp-action="Details" asp-route-id="@item.Listing.Id" class="text-decoration-none">
                        @item.Listing.Title
                    </a>
                </td>
                <td>@item.Listing.Description</td>
                <td>
                    <a asp-controller="UserProfile" asp-action="Details" asp-route-id="@item.Seller.Id" class="text-decoration-none">
                        @item.Seller.Username
                    </a>
                </td>
                <td>
                    @item.ReviewCount ocen@(item.ReviewCount == 1 ? "a" : ""), śr. @item.AverageRating.ToString("0.00")
                </td>
                <td>@item.Listing.Price</td>
                <td>
                    @if (!showArchived)
                    {
                        <a asp-action="EditListing" asp-route-id="@item.Listing.Id" class="btn btn-sm btn-warning me-1">Edytuj</a>
                        <form asp-action="DeleteListing" asp-route-id="@item.Listing.Id" method="post" style="display:inline;"
                              onsubmit="return confirm('Czy na pewno chcesz zarchiwizować tę ofertę?');">
                            <button type="submit" class="btn btn-sm btn-danger">Usuń</button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="RestoreListing" asp-route-id="@item.Listing.Id" method="post" style="display:inline;"
                              onsubmit="return confirm('Czy chcesz przywrócić tę ofertę?');">
                            <button type="submit" class="btn btn-sm btn-success">Przywróć</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
