@model List<ProjektZespolowyGr3.Models.ViewModels.BrowseListingsViewModel>

@{
    ViewData["Title"] = "Zarządzanie ofertami";
    bool showArchived = ViewBag.ShowArchived ?? false;
}

<div class="page-header mb-4">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title">@(showArchived ? "Archiwalne oferty" : "Aktywne oferty")</h2>
        </div>
        <div class="col-auto ms-auto">
            <a asp-action="Index" asp-route-showArchived="@(!showArchived)"
               class="btn @(showArchived ? "btn-primary" : "btn-outline-secondary")">
                @(showArchived ? "Pokaż aktywne" : "Pokaż archiwalne")
            </a>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body border-bottom py-3">
        <form asp-action="Index" method="get" class="row g-2 align-items-center">
            <input type="hidden" name="showArchived" value="@showArchived.ToString().ToLower()" />

            <div class="col-12 col-md">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="searchString" class="form-control" placeholder="Szukaj po ID, tytule lub sprzedającym..." value="@ViewBag.CurrentFilter" />
                    <button type="submit" class="btn btn-primary">Szukaj</button>
                </div>
            </div>

            <div class="col-auto">
                <label for="pageSize" class="form-label mb-0 small text-secondary">Limit</label>
            </div>
            <div class="col-auto">
                @{
                    int currentPageSize = ViewBag.CurrentPageSize ?? 25;
                    int[] sizes = new[] { 25, 50, 100, 500, 1000 };
                }
                <select id="pageSize" name="pageSize" class="form-select" style="width: 90px;" onchange="this.form.submit()">
                    @foreach (var size in sizes)
                    {
                        <option value="@size" selected="@(size == currentPageSize ? "selected" : null)">@size</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <label for="tagFilter" class="form-label mb-0 small text-secondary">Tag</label>
            </div>
            <div class="col-auto">
                @{
                    string currentTag = ViewBag.CurrentTag as string ?? "";
                    var tags = new[] { "" }.Concat((ViewBag.AllTags as IEnumerable<string>) ?? Enumerable.Empty<string>());
                }
                <select id="tagFilter" name="tagFilter" class="form-select" style="width: 150px;" onchange="this.form.submit()">
                    @foreach (var tag in tags)
                    {
                        var label = string.IsNullOrEmpty(tag) ? "-- Wszystkie --" : tag;
                        <option value="@tag" selected="@(tag == currentTag ? "selected" : null)">@label</option>
                    }
                </select>
            </div>
        </form>
    </div>

    <div class="table-responsive">
        <table class="table table-vcenter card-table">
            <thead>
                <tr>
                    <th>Tytuł</th>
                    <th>Opis</th>
                    <th>Sprzedający</th>
                    <th>Oceny</th>
                    <th>Cena</th>
                    <th class="w-1">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var canRestore = item.Listing.IsArchived && !item.Listing.IsDeleted && !item.Listing.IsSold && item.Listing.StockQuantity > 0;
                    var inactiveStatus = item.Listing.IsDeleted
                        ? "Usunięta"
                        : item.Listing.IsSold
                            ? "Sprzedana"
                            : item.Listing.StockQuantity <= 0
                                ? "Wyprzedana"
                                : "Niedostępna";

