@model ProjektZespolowyGr3.Models.ViewModels.EditListingViewModel
@{
    ViewBag.Title = "Edit listing";
    var modelId = ViewBag.ModelId;
}

<h2 class="mb-4">Edit listing</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form id="edit-listing-form" asp-action="EditListing" asp-route-id="@modelId" method="post" enctype="multipart/form-data" class="w-75">

    <div class="mb-3">
        <label asp-for="Title" class="form-label" id="label-Title">Title</label>
        <input asp-for="Title" class="form-control" id="input-Title" />
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label" id="label-Description">Description</label>
        <textarea asp-for="Description" class="form-control" rows="4" id="input-Description"></textarea>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label" id="label-Price">Price</label>
        <input asp-for="Price" type="number" class="form-control" step="0.01" id="input-Price" />
    </div>

    <div class="mb-3">
        <label asp-for="StockQuantity" class="form-label" id="label-StockQuantity">Liczba sztuk</label>
        <input asp-for="StockQuantity" type="number" min="0" class="form-control" id="input-StockQuantity" />
        <small class="text-muted">0 = wyprzedane (ogłoszenie oznaczone jako sprzedane).</small>
        <span asp-validation-for="StockQuantity" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label" id="label-SelectedTagIds">Tags</label>
        <select asp-for="SelectedTagIds" asp-items="Model.AvailableTags" multiple class="form-control" id="input-SelectedTagIds">
        </select>
        <small class="text-muted">Hold CTRL to select multiple</small>
    </div>

    <div class="card mb-3 border-info">
        <div class="card-header">Wymiana</div>
        <div class="card-body">
            <div class="form-check mb-3">
                <input asp-for="NotExchangeable" class="form-check-input" id="input-NotExchangable" />
                <label asp-for="NotExchangeable" class="form-check-label" id="label-NotExchangable">Nie do wymiany</label>
            </div>
            <div class="mb-3">
                <label asp-for="MinExchangeValue" class="form-label" id="label-MinExchangeValue">Minimalna wartość oferty kupującego (PLN)</label>
                <input asp-for="MinExchangeValue" type="number" step="0.01" min="0" class="form-control" id="input-MinExchangeValue"/>
            </div>
            <div class="mb-3">
                <label asp-for="ExchangeDescription" class="form-label" id="label-ExchangeDescription">Czego szukasz w zamian</label>
                <textarea asp-for="ExchangeDescription" class="form-control" rows="3" id="input-ExchangeDescription"></textarea>
            </div>
            <div class="mb-0">
                <label class="form-label" id="label-SelectedExchangeAcceptedTagIds">Akceptowane tagi przy wymianie</label>
                <select asp-for="SelectedExchangeAcceptedTagIds" asp-items="Model.AvailableTags" multiple class="form-control" id="input-SelectedExchangeAcceptedTagIds"></select>
            </div>
        </div>
    </div>

    <h4 class="mt-4">Existing Photos</h4>
    <div class="row">
        @if (Model.Photos != null && Model.Photos.Any())
        {
            foreach (var photo in Model.Photos)
            {
                <div class="col-3 text-center mb-4">
                    <img src="@photo.Upload.Url" class="img-fluid rounded mb-2" style="max-height: 150px;" />

                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" name="PhotosToDelete" value="@photo.Id" />
                        <label class="form-check-label">Delete</label>
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted">No photos uploaded.</p>
        }
    </div>

    <div class="mb-3 mt-4">
        <label class="form-label">Add new photos</label>
        <input asp-for="PhotoFiles" type="file" class="form-control" multiple />
        <small class="text-muted">Max 5 photos, only .jpg/.jpeg/.png</small>
    </div>

    <div class="form-check mb-3">
        <label asp-for="IsFeatured" class="form-check-label" id="label-IsFeatured">Wyróżnij na profilu</label>
        <input asp-for="IsFeatured" class="form-check-input" id="input-IsFeatured" />
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Save</button>
        <a class="btn btn-danger" asp-action="Index">Cancel</a>
    </div>
</form>

<script>
    const notExchangableSelect = document.getElementById('input-NotExchangable');
    const priceLabel = document.getElementById('label-Price');

    const priceLabelText = "Cena (PLN)";

    function toggleIsPriceRequired() {
        priceLabel.textContent = priceLabelText + (notExchangableSelect.checked ? " *" : "");
    }
    notExchangableSelect.addEventListener('change', toggleIsPriceRequired);
    toggleIsPriceRequired();

    const initialValues = {
        Title: '@(Model.Title ?? "")',
        Description: '@(Model.Description ?? "")',
        Price: '@Model.Price',
        SelectedTagIds: '@string.Join(",", (Model.SelectedTagIds ?? new List<int>()).OrderBy(id => id))',
        StockQuantity: '@Model.StockQuantity',
        NotExchangable: '@Model.NotExchangeable.ToString().ToLower()',
        MinExchangeValue: '@Model.MinExchangeValue',
        ExchangeDescription: '@(Model.ExchangeDescription ?? "")',
        SelectedExchangeAcceptedTagIds: '@string.Join(",", (Model.SelectedExchangeAcceptedTagIds ?? new List<int>()).OrderBy(id => id))',
        IsFeatured: '@Model.IsFeatured.ToString().ToLower()'
    };

    function updateLabel(field, value) {
        const label = document.getElementById('label-' + field);
        if (label) {
            label.style.fontWeight = value !== initialValues[field] ? 'bold' : 'normal';
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        const fields = initialValues ? Object.keys(initialValues) : [];

        fields.forEach(function (field) {
            const input = document.getElementById('input-' + field);
            if (input) {
                if (input.type === "checkbox") {
                    input.addEventListener('change', function () {
                        updateLabel(field, input.checked.toString());
                    });
                } else if (input.multiple) {
                    input.addEventListener('change', function () {
                        const selectedValues = Array.from(input.selectedOptions).map(option => option.value).join(",");
                        updateLabel(field, selectedValues);
                    });
                } else {
                    input.addEventListener('input', function () {
                        updateLabel(field, input.value);
                    });
                }
            }
        });

        const form = document.getElementById('edit-listing-form');
        form.addEventListener('submit', function (e) {
            let changedFields = [];
            fields.forEach(function (field) {
                const input = document.getElementById('input-' + field);
                let value;
                if (input) {
                    if (input.type === "checkbox") {
                        value = input.checked.toString();
                    } else if (input.multiple) {
                        value = Array.from(input.selectedOptions).map(option => option.value).join(",");
                    } else {
                        value = input.value;
                    }
                    if (value != initialValues[field]) {
                        changedFields.push(field);
                    }
                }
            });

            if (changedFields.length > 0) {
                const fieldNames = changedFields.map(f => {
                    switch (f) {
                        case 'SelectedTagIds': return 'Tags';
                        case 'SelectedExchangeAcceptedTagIds': return 'Accepted exchange tags'
                        default: return f;
                    }
                });
                const msg = "Are you sure you want to change " + fieldNames.join(", ") + "?";
                if (!confirm(msg)) {
                    e.preventDefault();
                }
            }
        });
    });
</script>