@model List<ProjektZespolowyGr3.Models.DbModels.Notification>
@using ProjektZespolowyGr3.Models.DbModels
@{
    ViewData["Title"] = "Powiadomienia";
}

<div class="page-header mb-4">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title">Powiadomienia</h2>
        </div>
        @if (Model.Any(n => !n.IsRead))
        {
            <div class="col-auto ms-auto">
                <form asp-action="MarkAllRead" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary"><i class="bi bi-check2-all me-1"></i> Oznacz wszystkie jako przeczytane</button>
                </form>
            </div>
        }
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="card card-md">
        <div class="card-body">
            <div class="empty">
                <div class="empty-icon"><i class="bi bi-bell-slash fs-1 text-secondary"></i></div>
                <p class="empty-title">Brak powiadomień</p>
                <p class="empty-subtitle text-secondary">Nowe powiadomienia pojawią się tutaj.</p>
            </div>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="list-group list-group-flush">
            @foreach (var n in Model)
            {
                <div class="list-group-item @(n.IsRead ? "" : "bg-primary-lt")">
                    <div class="row align-items-center g-2">
                        <div class="col">
                            @switch (n.Kind)
                            {
                                case NotificationKind.NewMessage:
                                    <strong>Nowa wiadomość</strong>
                                    <span class="text-secondary">od @(n.Message?.Sender?.Username ?? "użytkownika")</span>
                                    @if (n.Message != null && n.Message.Content.Length > 0 && n.Message.TradeProposalId == null)
                                    {
                                        <div class="small text-secondary text-truncate" style="max-width: 36rem;">@n.Message.Content</div>
                                    }
                                    break;
                                case NotificationKind.ListingPurchased:
                                    <strong>Zakupiono Twoje ogłoszenie</strong>
                                    <span class="text-secondary">@(n.Order?.Listing?.Title ?? "-")</span>
                                    break;
                                case NotificationKind.TradeProposalReceived:
                                    <strong>Nowa propozycja wymiany</strong>
                                    <span class="text-secondary">od @(n.TradeProposal?.Initiator?.Username ?? "?")</span>
                                    @if (n.TradeProposal?.SubjectListing != null)
                                    {
                                        <div class="small text-secondary">Kontekst: @n.TradeProposal.SubjectListing.Title</div>
                                    }
                                    break;
                            }
                            <div class="small text-secondary mt-1">@n.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                        </div>
                        <div class="col-auto">
                            <a asp-action="Go" asp-route-id="@n.Id" class="btn btn-sm btn-primary">Otwórz</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
