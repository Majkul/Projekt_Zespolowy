@model ProjektZespolowyGr3.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Logowanie";
    ViewData["HideNavSearch"] = true;
    if (!string.IsNullOrEmpty(ViewBag.Alert))
        @ViewBag.Alert
}

<div class="row justify-content-center">
    <div class="col-12 col-sm-9 col-md-7 col-lg-5">
        <div class="text-center mb-4">
            <h2 class="h2">Zaloguj się</h2>
            <p class="text-secondary mb-0">Witaj ponownie w HandlujZTym</p>
        </div>

        <div class="card card-md">
            <div class="card-body">
                @if (TempData["AlertSuccess"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                        @TempData["AlertSuccess"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Login">
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    <div class="mb-3">
                        <label asp-for="Login" class="form-label">Login</label>
                        <input asp-for="Login" class="form-control" placeholder="Twój login" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Hasło</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Hasło" />
                        <div class="form-hint text-end">
                            <a asp-action="ForgotPassword">Nie pamiętasz hasła?</a>
                        </div>
                    </div>

                    @if (TempData["AlertErrorLogin"] != null)
                    {
                        <div class="alert alert-danger" role="alert">@TempData["AlertErrorLogin"]</div>
                    }

                    <div class="form-footer">
                        <button type="submit" class="btn btn-primary w-100">Zaloguj</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="text-center text-secondary mt-3">
            Nie masz konta? <a asp-action="Register">Zarejestruj się</a>
        </div>
    </div>
</div>
