@model ProjektZespolowyGr3.Models.ViewModels.LoginViewModel

@{
    if (!string.IsNullOrEmpty(ViewBag.Alert))
        @ViewBag.Alert

}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="mb-4 text-center">Logowanie</h2>
            <form asp-action="Login">
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                <div class="mb-3">
                    <label asp-for="Login" class="form-label">Login</label>
                    <input asp-for="Login" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Hasło</label>
                    <input asp-for="Password" type="password" class="form-control" />
                </div>
                <div class="d-flex justify-content-between">
                    <a class="btn btn-outline-secondary" asp-action="Index">Powrót</a>
                    <input type="submit" value="Zaloguj" class="btn btn-primary" />
                </div>
            </form>
        </div>
    </div>
    <div class="form-group">
        <label asp-for="Password" class="control-label"></label>
        <input asp-for="Password" type="password" class="form-control" />
    </div>
    @Html.ValidationSummary(false, "", new { @class = "text-danger" })
    <div class="form-group">
        @Html.LabelFor(m => m.Login)
        @Html.TextBoxFor(m => m.Login, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Login, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.Password)
        @Html.PasswordFor(m => m.Password, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        <input type="submit" value="Zaloguj" class="btn btn-success" /><a class="btn btn-info" asp-action="Index">Powrót</a>
    </div>
</div>

