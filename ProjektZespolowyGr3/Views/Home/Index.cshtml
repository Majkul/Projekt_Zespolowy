@using ProjektZespolowyGr3.Models.DbModels
@{
    ViewData["Title"] = "Strona główna";
    var latestListings = ViewBag.LatestListings as List<Listing> ?? new List<Listing>();
    var saleCount = latestListings.Count(l => l.Price.HasValue);
    var tradeCount = latestListings.Count(l => !l.NotExchangeable);
    var newListingsLabel = ListingPresentationHelper.FormatNewListingsCount(latestListings.Count).Substring(latestListings.Count.ToString().Length).TrimStart();
    var saleListingsLabel = ListingPresentationHelper.FormatSaleListingsCount(saleCount).Substring(saleCount.ToString().Length).TrimStart();
    var tradeListingsLabel = ListingPresentationHelper.FormatTradeListingsCount(tradeCount).Substring(tradeCount.ToString().Length).TrimStart();
}

<section class="market-hero mb-5">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="badge bg-white text-primary mb-3">Lokalny marketplace</span>
            <h1 class="display-4 fw-bold mb-3">Kupuj, sprzedawaj i wymieniaj bez kombinowania</h1>
            <p class="lead mb-0">
                Przeglądaj ogłoszenia z okolicy, znajdź coś w dobrej cenie albo zaproponuj wymianę zamiast klasycznej sprzedaży.
            </p>

            <form asp-controller="Listings" asp-action="Index" method="get" class="mt-4">
                <div class="input-group input-group-lg">
                    <input type="text" name="searchString" class="form-control" placeholder="Czego dziś szukasz?" aria-label="Szukaj ofert">
                    <button class="btn btn-warning" type="submit">
                        <i class="bi bi-search me-1"></i> Szukaj
                    </button>
                </div>
            </form>

            <div class="d-flex flex-wrap gap-2 mt-4">
                <a asp-controller="Listings" asp-action="Index" class="btn btn-light">
                    <i class="bi bi-grid me-1"></i> Przeglądaj oferty
                </a>
                <a asp-controller="Listings" asp-action="Create" class="btn btn-outline-light">
                    <i class="bi bi-plus-circle me-1"></i> Dodaj ofertę
                </a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="market-hero-panel">
                <div class="market-hero-summary">
                    <div>
                        <div class="text-white-50 small">Na stronie głównej</div>
                        <h2 class="h4 mb-0">Najnowsze ogłoszenia</h2>
                    </div>
                    <i class="bi bi-bag-check market-hero-panel-icon text-warning"></i>
                </div>
                <div class="market-stat-grid">
                    <div class="market-stat">
                        <div class="market-stat-value">@latestListings.Count</div>
                        <div class="market-stat-label">@newListingsLabel</div>
                    </div>
                    <div class="market-stat">
                        <div class="market-stat-value">@saleCount</div>
                        <div class="market-stat-label">@saleListingsLabel</div>
                    </div>
                    <div class="market-stat">
                        <div class="market-stat-value">@tradeCount</div>
                        <div class="market-stat-label">@tradeListingsLabel</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mb-5">
    <div class="section-heading">
        <div>
            <span class="text-uppercase small fw-bold text-primary">Świeże okazje</span>
            <h2 class="mb-1">Najnowsze oferty</h2>
            <p class="mb-0">Szybki podgląd tego, co ostatnio dodali użytkownicy.</p>
        </div>
        <a asp-controller="Listings" asp-action="Index" class="btn btn-outline-primary">
            Zobacz wszystkie
        </a>
    </div>

    @if (latestListings.Any())
    {
        <div class="row listing-grid">
            @foreach (var listing in latestListings)
            {
                var isSale = listing.Price.HasValue;
                var badges = ListingPresentationHelper.GetListingBadges(listing);
                <div class="col-sm-6 col-xl-3">
                    <article class="card listing-card h-100">
                        <div class="ratio ratio-4x3 listing-card-media">
                            @if (listing.Photos != null && listing.Photos.Any())
                            {
                                var featuredPhoto = listing.Photos.FirstOrDefault(p => p.IsFeatured) ?? listing.Photos.First();
                                <img src="@featuredPhoto.Upload.Url" class="listing-card-img" alt="@listing.Title">
                            }
                            else
                            {
                                <div class="listing-card-placeholder">
                                    <i class="bi bi-image"></i>
                                    <span>Brak zdjęcia</span>
                                </div>
                            }
                        </div>
                        <div class="card-body d-flex flex-column">
                            <div class="listing-statuses">
                                @foreach (var badge in badges)
                                {
                                    <span class="badge @badge.CssClass">@badge.Label</span>
                                }
                            </div>
                            <h3 class="h5 card-title mb-2">@listing.Title</h3>
                            @if (!string.IsNullOrEmpty(listing.Description))
                            {
                                <p class="card-text text-muted small">
                                    @(listing.Description.Length > 86 ? listing.Description.Substring(0, 86) + "..." : listing.Description)
                                </p>
                            }
                            <div class="mt-auto">
                                @if (isSale)
                                {
                                    <div class="listing-price fw-bold mb-3">@listing.Price.FormatPricePLN()</div>
                                }
                                else
                                {
                                    <div class="mb-3">
                                        <span class="badge bg-green-lt">Otwarta wymiana</span>
                                    </div>
                                }
                                <a asp-controller="Listings" asp-action="Details" asp-route-slug="@SlugHelper.GenerateSlug(listing.Title)" asp-route-id="@listing.Id" class="btn btn-primary w-100">
                                    Zobacz szczegóły
                                </a>
                            </div>
                        </div>
                        <div class="card-footer bg-white">
                            <div class="d-flex justify-content-between align-items-center small">
                                <a asp-controller="UserProfile" asp-action="Details" asp-route-username="@listing.Seller.Username" class="listing-meta text-decoration-none">
                                    <i class="bi bi-person-circle"></i>
                                    <span>@listing.Seller.Username</span>
                                </a>
                                <span class="text-muted">@listing.CreatedAt.ToString("dd.MM.yyyy")</span>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card card-md">
            <div class="card-body">
                <div class="empty">
                    <div class="empty-icon"><i class="bi bi-bag fs-1"></i></div>
                    <p class="empty-title">Brak dostępnych ofert</p>
                    <p class="empty-subtitle text-secondary">Dodaj pierwszą ofertę i rozkręć marketplace.</p>
                    <div class="empty-action">
                        <a asp-controller="Listings" asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Dodaj ofertę</a>
                    </div>
                </div>
            </div>
        </div>
    }
</section>

<section class="mb-5">
    <div class="section-heading">
        <div>
            <span class="text-uppercase small fw-bold text-primary">Historia</span>
            <h2 class="mb-1">Ostatnio oglądane</h2>
            <p class="mb-0">Wracaj szybko do ofert, które już sprawdzałeś.</p>
        </div>
    </div>
    <div id="viewing-history" class="row listing-grid"></div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            function generateSlug(value) {
                return (value || '')
                    .toLowerCase()
                    .replace(/[ąćęłńóśżź]/g, function(match) {
                        return {
                            'ą': 'a',
                            'ć': 'c',
                            'ę': 'e',
                            'ł': 'l',
                            'ń': 'n',
                            'ó': 'o',
                            'ś': 's',
                            'ż': 'z',
                            'ź': 'z'
                        }[match];
                    })
                    .replace(/[^a-z0-9]+/g, '-')
                    .replace(/-+/g, '-')
                    .replace(/^-|-$/g, '')
                    .substring(0, 60)
                    .replace(/-$/g, '');
            }

            var history = JSON.parse(localStorage.getItem('listingHistory') || '[]');
            var container = document.getElementById('viewing-history');
            if (history.length === 0) {
                container.innerHTML = '<div class="col-12"><div class="card"><div class="card-body text-secondary text-center">Brak historii oglądania.</div></div></div>';
                return;
            }
            history.forEach(function(listing) {
                var slug = listing.slug || generateSlug(listing.title);
                var html = `
                <div class="col-sm-6 col-xl-3">
                    <article class="card listing-card h-100">
                        <div class="ratio ratio-4x3 listing-card-media">
                            ${listing.image ? `<img src="${listing.image}" class="listing-card-img" alt="${listing.title}">` : `
                            <div class="listing-card-placeholder">
                                <i class="bi bi-image"></i>
                                <span>Brak zdjęcia</span>
                            </div>`}
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h3 class="h5 card-title">${listing.title}</h3>
                            <div class="mt-auto">
                                <a href="/Listings/${slug}-${listing.id}" class="btn btn-primary w-100">Zobacz szczegóły</a>
                            </div>
                        </div>
                    </article>
                </div>
                `;
                container.innerHTML += html;
            });
        });
    </script>
}
