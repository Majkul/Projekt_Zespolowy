@{
    ViewData["Title"] = "Potwierdzenie rejestracji";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body text-center">
                    <h2 class="mb-4">Dziękujemy za rejestrację!</h2>
                    <p class="lead">Wysłaliśmy link aktywacyjny na Twój adres email.</p>
                    <p>Kliknij w link w wiadomości, aby aktywować swoje konto.</p>
                    <a asp-action="Index" class="btn btn-primary mt-3">Powrót do strony głównej</a>
                </div>
            </div>
        </div>
    </div>
</div>
