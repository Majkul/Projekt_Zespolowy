@model ProjektZespolowyGr3.Models.DbModels.Ticket
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Szczegóły ticketu";
    var statusSelectItems = ViewBag.Statuses as List<SelectListItem> ?? new List<SelectListItem>();
    var adminSelectItems = ViewBag.Admins as List<SelectListItem> ?? new List<SelectListItem>();

    string GetDisplayName(Enum value)
    {
        var type = value.GetType();
        var memInfo = type.GetMember(value.ToString());
        if (memInfo.Length > 0)
        {
            var attributes = memInfo[0].GetCustomAttributes(typeof(DisplayAttribute), false);
            if (attributes.Length > 0)
            {
                return ((DisplayAttribute)attributes[0]).Name ?? value.ToString();
            }
        }
        return value.ToString().Replace("_", " ");
    }

    string StatusBadge(TicketStatus s) => s switch
    {
        TicketStatus.Open => "bg-yellow-lt",
        TicketStatus.Resolved => "bg-green-lt",
        TicketStatus.In_Progress => "bg-blue-lt",
        _ => "bg-secondary-lt"
    };
}

<div class="page-header mb-4">
    <h2 class="page-title">Szczegóły ticketu #@Model.Id</h2>
</div>

@if (TempData["AlertSuccess"] != null)
{
    <div class="alert alert-success" role="alert">@TempData["AlertSuccess"]</div>
}
@if (TempData["AlertError"] != null)
{
    <div class="alert alert-danger" role="alert">@TempData["AlertError"]</div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header"><h3 class="card-title">@Model.Subject</h3></div>
            <div class="card-body">
                <p class="mb-2"><strong>Kategoria:</strong> <span class="badge bg-azure-lt ms-1">@GetDisplayName(Model.Category)</span></p>
                <p class="mb-3"><strong>Status:</strong> <span class="badge @StatusBadge(Model.Status) ms-1">@GetDisplayName(Model.Status)</span></p>
                <hr />
                <p class="mb-1"><strong>Opis:</strong></p>
                <p class="mb-0">@Model.Description</p>
            </div>
        </div>

        @if (Model.Attachments != null && Model.Attachments.Any())
        {
            <div class="card mb-3">
                <div class="card-header"><h3 class="card-title">Załączniki</h3></div>
                <div class="list-group list-group-flush">
                    @foreach (var attachment in Model.Attachments)
                    {
                        <div class="list-group-item">
                            @if (attachment.IsDeleted)
                            {
                                <span class="text-secondary"><i class="bi bi-paperclip me-1"></i>Usunięty załącznik</span>
                            }
                            else
                            {
                                <a href="@attachment.Upload.Url" target="_blank"><i class="bi bi-paperclip me-1"></i>@attachment.Upload.FileName</a>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header"><h3 class="card-title">Informacje</h3></div>
            <div class="card-body">
                <p><strong>Użytkownik:</strong>
                    <a asp-controller="UserProfile" asp-action="Details" asp-route-username="@Model.User.Username">@Model.User.Username</a>
                </p>
                <p><strong>Data utworzenia:</strong> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                <p><strong>Ostatnia aktywność:</strong> @Model.LastActivity.ToString("dd.MM.yyyy HH:mm")</p>
                @if (Model.ReportedUser != null)
                {
                    <p><strong>Zgłoszony użytkownik:</strong> <a asp-controller="UserProfile" asp-action="Details" asp-route-username="@Model.ReportedUser.Username">@Model.ReportedUser.Username</a></p>
                }
                @if (Model.ReportedListing != null)
                {
                    <p><strong>Zgłoszona oferta:</strong> <a asp-controller="Listings" asp-action="Details" asp-route-slug="@SlugHelper.GenerateSlug(Model.ReportedListing.Title)" asp-route-id="@Model.ReportedListing.Id">@Model.ReportedListing.Title</a></p>
                }

                <hr />
                <a asp-controller="Messages" asp-action="Conversation" asp-route-userId="@Model.UserId" asp-route-ticketId="@Model.Id" class="btn btn-outline-primary w-100 mb-2">
                    <i class="bi bi-envelope me-1"></i>Skontaktuj się ze zgłaszającym
                </a>

                @if (Model.AssigneeId.HasValue)
                {
                    <a asp-controller="Messages" asp-action="Conversation" asp-route-userId="@Model.AssigneeId" asp-route-ticketId="@Model.Id" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-person-badge me-1"></i>Skontaktuj się z przypisanym administratorem
                    </a>
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><h3 class="card-title">Akcje</h3></div>
            <div class="card-body">
                <form asp-action="UpdateStatus" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="mb-2">
                        <label class="form-label">Status</label>
                        <select name="status" class="form-select">
                            @foreach (var status in statusSelectItems)
                            {
                                <option value="@status.Value" selected="@status.Selected">@status.Text</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Zaktualizuj status</button>
                </form>

                <form asp-action="Assign" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="mb-2">
                        <label class="form-label">Przypisz do</label>
                        <select name="assigneeId" class="form-select">
                            <option value="">Nieprzypisany</option>
                            @foreach (var admin in adminSelectItems)
                            {
                                <option value="@admin.Value" selected="@admin.Selected">@admin.Text</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-outline-secondary w-100">Przypisz</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">Powrót do listy</a>
</div>
