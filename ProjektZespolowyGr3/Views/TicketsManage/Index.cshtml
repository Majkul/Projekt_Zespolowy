@model List<ProjektZespolowyGr3.Models.DbModels.Ticket>
@using ProjektZespolowyGr3.Models.DbModels
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Zarządzanie ticketami";
    var statusSelectItems = ViewBag.Statuses as List<SelectListItem> ?? new List<SelectListItem>();
    var categorySelectItems = ViewBag.Categories as List<SelectListItem> ?? new List<SelectListItem>();
    var adminSelectItems = ViewBag.Admins as List<SelectListItem> ?? new List<SelectListItem>();

    string GetDisplayName(Enum value)
    {
        var type = value.GetType();
        var memInfo = type.GetMember(value.ToString());
        if (memInfo.Length > 0)
        {
            var attributes = memInfo[0].GetCustomAttributes(typeof(DisplayAttribute), false);
            if (attributes.Length > 0)
            {
                return ((DisplayAttribute)attributes[0]).Name ?? value.ToString();
            }
        }
        return value.ToString().Replace("_", " ");
    }

    string StatusBadge(TicketStatus s) => s switch
    {
        TicketStatus.Open => "bg-yellow-lt",
        TicketStatus.Resolved => "bg-green-lt",
        TicketStatus.In_Progress => "bg-blue-lt",
        _ => "bg-secondary-lt"
    };
}

<div class="page-header mb-4">
    <h2 class="page-title">Zarządzanie ticketami</h2>
</div>

<div class="card">
    <div class="card-body border-bottom py-3">
        <form method="get">
            <div class="row g-2">
                <div class="col-md-3">
                    <input type="text" name="searchString" class="form-control" placeholder="Szukaj..." value="@ViewBag.CurrentFilter">
                </div>
                <div class="col-md-2">
                    <select name="statusFilter" class="form-select">
                        <option value="">Wszystkie statusy</option>
                        @foreach (var status in statusSelectItems)
                        {
                            <option value="@status.Value" selected="@status.Selected">@status.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="categoryFilter" class="form-select">
                        <option value="">Wszystkie kategorie</option>
                        @foreach (var category in categorySelectItems)
                        {
                            <option value="@category.Value" selected="@category.Selected">@category.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="assigneeFilter" class="form-select">
                        <option value="">Wszyscy</option>
                        @foreach (var admin in adminSelectItems)
                        {
                            <option value="@admin.Value" selected="@admin.Selected">@admin.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary">Filtruj</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Wyczyść</a>
                </div>
            </div>
        </form>
    </div>

    <div class="table-responsive">
        <table class="table table-vcenter card-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Temat</th>
                    <th>Kategoria</th>
                    <th>Status</th>
                    <th>Użytkownik</th>
                    <th>Przypisany do</th>
                    <th>Data utworzenia</th>
                    <th class="w-1">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model)
                {
                    <tr>
                        <td class="text-secondary">@ticket.Id</td>
                        <td class="fw-bold">@ticket.Subject</td>
                        <td><span class="badge bg-azure-lt">@GetDisplayName(ticket.Category)</span></td>
                        <td><span class="badge @StatusBadge(ticket.Status)">@GetDisplayName(ticket.Status)</span></td>
                        <td>
                            <a asp-controller="UserProfile" asp-action="Details" asp-route-username="@ticket.User.Username" class="text-decoration-none">
                                @ticket.User.Username
                            </a>
                        </td>
                        <td class="text-secondary">@(ticket.Assignee?.Username ?? "Nieprzypisany")</td>
                        <td class="text-secondary">@ticket.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <a asp-action="Details" asp-route-slug="@SlugHelper.GenerateSlug(ticket.Subject)" asp-route-id="@ticket.Id" class="btn btn-sm btn-outline-primary">Szczegóły</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-center">
            <ul class="pagination m-0">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="?pageNumber=@i&searchString=@ViewBag.CurrentFilter&statusFilter=@ViewBag.StatusFilter&categoryFilter=@ViewBag.CategoryFilter&assigneeFilter=@ViewBag.AssigneeFilter">@i</a>
                    </li>
                }
            </ul>
        </div>
    }
</div>
