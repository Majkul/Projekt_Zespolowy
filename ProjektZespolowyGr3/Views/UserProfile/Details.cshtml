@model ProjektZespolowyGr3.Models.DbModels.User

@{
    ViewData["Title"] = "Profil użytkownika";
    var averageRating = ViewBag.AverageRating as double? ?? 0;
    var reviewCount = ViewBag.ReviewCount as int? ?? 0;
    var activeListings = ViewBag.ActiveListings as List<ProjektZespolowyGr3.Models.DbModels.Listing> ?? new List<ProjektZespolowyGr3.Models.DbModels.Listing>();
    activeListings = activeListings.OrderByDescending(l => l.IsFeatured).ToList();

    bool isAuthenticated = User.Identity?.IsAuthenticated == true;
    bool isProfileOwner = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == Model.Id.ToString();
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <span class="avatar avatar-lg me-3" style="background-image: url(/Images/Icons/user-icon.png)"></span>
                    <div>
                        <h3 class="m-0 text-break-anywhere">@Model.Username</h3>
                        @if (!string.IsNullOrEmpty(Model.FirstName) || !string.IsNullOrEmpty(Model.LastName))
                        {
                            <div class="text-secondary">@Model.FirstName @Model.LastName</div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ProfileDescription))
                {
                    <h4 class="text-secondary text-uppercase small fw-bold mt-4">O mnie</h4>
                    <p class="mb-0 text-break-anywhere">@Model.ProfileDescription</p>
                }

                <h4 class="text-secondary text-uppercase small fw-bold mt-4">Statystyki</h4>
                <dl class="row mb-0">
                    <dt class="col-6 text-secondary fw-normal">Średnia ocena</dt>
                    <dd class="col-6 text-end">
                        @if (averageRating > 0)
                        {
                            <span class="badge bg-green-lt"><i class="bi bi-star-fill me-1"></i>@averageRating.ToString("F2")</span>
                        }
                        else
                        {
                            <span class="text-secondary">Brak ocen</span>
                        }
                    </dd>
                    <dt class="col-6 text-secondary fw-normal">Liczba opinii</dt>
                    <dd class="col-6 text-end">@reviewCount</dd>
                    <dt class="col-6 text-secondary fw-normal">Aktywne oferty</dt>
                    <dd class="col-6 text-end">@activeListings.Count</dd>
                    <dt class="col-6 text-secondary fw-normal">Członek od</dt>
                    <dd class="col-6 text-end">@Model.CreatedAt.ToString("dd.MM.yyyy")</dd>
                </dl>

                @if (!string.IsNullOrEmpty(Model.Email) || !string.IsNullOrEmpty(Model.PhoneNumber) || !string.IsNullOrEmpty(Model.Address))
                {
                    <h4 class="text-secondary text-uppercase small fw-bold mt-4">Dane kontaktowe</h4>
                    <dl class="row mb-0">
                        @if (!string.IsNullOrEmpty(Model.Email))
                        {
                            <dt class="col-4 text-secondary fw-normal">Email</dt>
                            <dd class="col-8 text-end text-truncate">@Model.Email</dd>
                        }
                        @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                        {
                            <dt class="col-4 text-secondary fw-normal">Telefon</dt>
                            <dd class="col-8 text-end">@Model.PhoneNumber</dd>
                        }
                        @if (!string.IsNullOrEmpty(Model.Address))
                        {
                            <dt class="col-4 text-secondary fw-normal">Adres</dt>
                            <dd class="col-8 text-end">@Model.Address</dd>
                        }
                    </dl>
                }
            </div>

            @if (!isProfileOwner)
            {
                <div class="card-footer d-grid gap-2">
                    <a asp-controller="Messages" asp-action="Conversation" asp-route-userId="@Model.Id" class="btn btn-outline-primary">
                        <i class="bi bi-envelope me-1"></i> Napisz wiadomość
                    </a>
                    <a asp-controller="Tickets" asp-action="ReportUser" asp-route-userId="@Model.Id" class="btn btn-outline-danger">
                        <i class="bi bi-flag me-1"></i> Zgłoś użytkownika
                    </a>
                </div>
            }
            else
            {
                <div class="card-footer d-grid">
                    <a asp-controller="MyProfile" asp-action="Edit" class="btn btn-outline-secondary">Edytuj profil</a>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-8">
        <div class="section-heading">
            <h3 class="mb-0">Aktywne oferty</h3>
        </div>

        @if (activeListings.Any())
        {
            <div class="row listing-grid">
                @foreach (var listing in activeListings)
                {
                    <div class="col-sm-6">
                        <article class="card listing-card h-100@(listing.IsFeatured ? " listing-card-featured" : "")">
                            <div class="ratio ratio-4x3 listing-card-media">
                                @if (listing.IsFeatured)
                                {
                                    <span class="badge bg-yellow-lt listing-badge"><i class="bi bi-star-fill me-1"></i>Wyróżniona</span>
                                }
                                @if (listing.Photos != null && listing.Photos.Any())
                                {
                                    var featuredPhoto = listing.Photos.FirstOrDefault(p => p.IsFeatured) ?? listing.Photos.First();
                                    <img src="@featuredPhoto.Upload.Url" class="listing-card-img" alt="@listing.Title">
                                }
                                else
                                {
                                    <div class="listing-card-placeholder d-flex align-items-center justify-content-center">
                                        <span>Brak zdjęcia</span>
                                    </div>
                                }
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h4 class="h5 card-title mb-2 text-break-anywhere">@listing.Title</h4>
                                <div class="mt-auto">
                                    @if (listing.Price.HasValue)
                                    {
                                        <div class="listing-price mb-3">@listing.Price.FormatPricePLN()</div>
                                    }
                                    else
                                    {
                                        <div class="mb-3"><span class="badge bg-green-lt">Otwarta wymiana</span></div>
                                    }
                                    <a asp-controller="Listings" asp-action="Details" asp-route-slug="@SlugHelper.GenerateSlug(listing.Title)" asp-route-id="@listing.Id" class="btn btn-primary w-100">Zobacz szczegóły</a>
                                </div>
                            </div>
                        </article>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="card card-md">
                <div class="card-body">
                    <div class="empty">
                        <div class="empty-icon"><i class="bi bi-bag fs-1 text-secondary"></i></div>
                        <p class="empty-title">Brak aktywnych ofert</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
