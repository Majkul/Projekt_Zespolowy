@section Scripts {
<script>
    let shippingCount = 0;
    function addShippingRow() {
        const container = document.getElementById('shipping-options-container');
        const row = document.createElement('div');
        row.className = 'row g-2 mb-2 shipping-option-row';
        row.innerHTML = `
            <div class="col-7">
                <input name="ShippingOptions[${shippingCount}].Name" class="form-control" placeholder="Np. InPost Paczkomat, DPD, Odbiór osobisty…" />
            </div>
            <div class="col-3">
                <div class="input-group">
                    <input name="ShippingOptions[${shippingCount}].Price" type="number" step="0.01" min="0" value="0" class="form-control" placeholder="0.00" />
                    <span class="input-group-text">PLN</span>
                </div>
            </div>
            <div class="col-2">
                <button type="button" class="btn btn-outline-danger w-100" onclick="removeShippingRow(this)">✕</button>
            </div>`;
        container.appendChild(row);
        shippingCount++;
    }
    function removeShippingRow(btn) {
        btn.closest('.shipping-option-row').remove();
        reindexShippingRows();
    }
    function reindexShippingRows() {
        const rows = document.querySelectorAll('.shipping-option-row');
        rows.forEach((row, i) => {
            const nameInput = row.querySelector('input[name*=".Name"]');
            const priceInput = row.querySelector('input[name*=".Price"]');
            if (nameInput) nameInput.name = `ShippingOptions[${i}].Name`;
            if (priceInput) priceInput.name = `ShippingOptions[${i}].Price`;
        });
        shippingCount = rows.length;
    }
</script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        @if (!isForTrade)
        {
            <text>
        const notExchangeableSelect = document.getElementById('not-exchangable-select');
        const priceLabel = document.getElementById('price-label');
        const tradeGroup = document.getElementById('trade-group');

        function toggleIsPriceRequired() {
            priceLabel.textContent = "Cena (PLN)" + (notExchangeableSelect.checked ? " *" : "");
        }
        function toggleTradeGroup() {
            const disabled = notExchangeableSelect.checked;
            tradeGroup.style.display = disabled ? 'none' : 'block';
            tradeGroup.querySelectorAll('input, textarea, select').forEach(function (input) {
                input.disabled = disabled;
                if (disabled) {
                    if (input.multiple) {
                        Array.from(input.options).forEach(option => option.selected = false);
                    } else {
                        input.value = '';
                    }
                }
            });
        }
        notExchangeableSelect.addEventListener('change', toggleIsPriceRequired);
        notExchangeableSelect.addEventListener('change', toggleTradeGroup);
        toggleIsPriceRequired();
        toggleTradeGroup();
            </text>
        }

        @if (isForTrade && forTradeAcceptedTagIds.Any())
        {
            <text>
            var requiredTagIds = @Html.Raw("[" + string.Join(",", forTradeAcceptedTagIds) + "]");
            document.querySelectorAll('#tagSelectCreate option').forEach(function(opt) {
                if (requiredTagIds.includes(parseInt(opt.value))) {
                    opt.style.fontWeight = 'bold';
                    opt.textContent = opt.textContent + ' *';
                }
            });
            </text>
        }
    </script>
}
