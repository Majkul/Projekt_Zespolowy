@model ProjektZespolowyGr3.Models.ViewModels.CreateListingViewModel

@{
    ViewData["Title"] = "Dodaj ogłoszenie";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            @{
                var forTradeListingId = ViewBag.ForTradeListingId as int?;
                var forTradeTitle = ViewBag.ForTradeListingTitle as string;
                var forTradeAcceptedTagIds = ViewBag.ForTradeAcceptedTagIds as List<int> ?? new List<int>();
                var forTradeAcceptedTagNames = ViewBag.ForTradeAcceptedTagNames as List<string> ?? new List<string>();
                bool isForTrade = forTradeListingId.HasValue;
            }

            @if (isForTrade)
            {
                <div class="alert alert-info d-flex align-items-start gap-2 mb-3">
                    <span class="fs-5">🔒</span>
                    <div>
                        <strong>Ogłoszenie prywatne pod wymianę</strong><br />
                        Tworzysz ofertę w kontekście ogłoszenia <strong>@forTradeTitle</strong>.
                        Będzie widoczne tylko w Twojej puli wymiany.
                        @if (forTradeAcceptedTagNames.Any())
                        {
                            <span>Wymagany co najmniej jeden z tagów: <strong>@string.Join(", ", forTradeAcceptedTagNames)</strong>.</span>
                        }
                    </div>
                </div>
            }

            <h2 class="mb-4">Dodaj nowe ogłoszenie</h2>
            <hr />

            <form asp-action="Create" enctype="multipart/form-data">
                @if (isForTrade)
                {
                    <input type="hidden" name="forTradeListingId" value="@forTradeListingId" />
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                }

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-bold">Tytuł ogłoszenia *</label>
                    <input asp-for="Title" class="form-control" placeholder="Np. Komputer gamingowy" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold">Opis</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Opisz szczegółowo swoją ofertę..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="tagSelectCreate" class="form-label fw-bold">Kategorie</label>
                    <select asp-for="SelectedTagIds" asp-items="Model.AvailableTags" multiple class="form-select" id="tagSelectCreate">
                    </select>
                    <span asp-validation-for="SelectedTagIds" class="text-danger"></span>
                </div>

                @if (isForTrade)
                {
                    <input type="hidden" name="NotExchangeable" value="false" />
                    <input type="hidden" name="IsPrivate" value="true" />
                    <input type="hidden" name="IsFeatured" value="false" />
                }
                else
                {
                    <div class="form-check mb-3">
                        <input asp-for="NotExchangeable" class="form-check-input" id="not-exchangable-select" />
                        <label asp-for="NotExchangeable" class="form-check-label">Nie do wymiany</label>
                    </div>
                }

                @if (!isForTrade)
                {
                    <div class="card mb-3 border-info" id="trade-group">
                        <div class="card-header bg-info bg-opacity-10">Wymiana</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label asp-for="MinExchangeValue" class="form-label">Minimalna wartość oferty kupującego (PLN)</label>
                                <input asp-for="MinExchangeValue" type="number" step="0.01" min="0" class="form-control" />
                                <small class="text-muted">Pusta wartość = brak progu.</small>
                            </div>
                            <div class="mb-3">
                                <label asp-for="ExchangeDescription" class="form-label">Czego szukasz w zamian</label>
                                <textarea asp-for="ExchangeDescription" class="form-control" rows="3" placeholder="Np. interesują mnie tylko książki fantasy…"></textarea>
                            </div>
                            <div class="mb-0">
                                <label for="tagSelectCreateExchange" class="form-label">Akceptowane tagi przy wymianie</label>
                                <select asp-for="SelectedExchangeAcceptedTagIds" asp-items="Model.AvailableTags" multiple class="form-select" id="tagSelectCreateExchange">
                                </select>
                                <small class="text-muted">Jeśli nic nie wybierzesz - dowolne kategorie.</small>
                            </div>
                        </div>
                    </div>
                }

                <div class="mb-3" id="price-group">
                    <label asp-for="Price" class="form-label fw-bold" id="price-label">Cena (PLN)</label>
                    <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="StockQuantity" class="form-label fw-bold">Liczba sztuk *</label>
                    <input asp-for="StockQuantity" type="number" min="1" class="form-control" />
                    <small class="text-muted">Ile identycznych przedmiotów sprzedajesz / wystawiasz do wymiany w tym ogłoszeniu.</small>
                    <span asp-validation-for="StockQuantity" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PhotoFiles" class="form-label fw-bold">Zdjęcia (maksymalnie 5)</label>
                    <div class="image-upload-container">
                        <input asp-for="PhotoFiles" type="file" multiple accept=".jpg,.jpeg,.png" class="form-control image-upload-input" />
                    </div>
                    <small class="form-text text-muted">Pierwsze zdjęcie będzie zdjęciem głównym. Możesz przesłać maksymalnie 5 zdjęć.</small>
                    <span asp-validation-for="PhotoFiles" class="text-danger"></span>
                </div>

                @if (!isForTrade)
                {
                    <div class="form-check mb-3">
                        <label asp-for="IsFeatured" class="form-check-label">Wyróżnij na profilu</label>
                        <input asp-for="IsFeatured" class="form-check-input" />
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="IsPrivate" class="form-check-input" />
                        <label asp-for="IsPrivate" class="form-check-label">Ogłoszenie prywatne</label>
                    </div>
                }

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
                    <input type="submit" value="Utwórz ogłoszenie" class="btn btn-primary" />
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        @if (!isForTrade)
        {
            <text>
        const notExchangeableSelect = document.getElementById('not-exchangable-select');
        const priceLabel = document.getElementById('price-label');
        const tradeGroup = document.getElementById('trade-group');

        function toggleIsPriceRequired() {
            priceLabel.textContent = "Cena (PLN)" + (notExchangeableSelect.checked ? " *" : "");
        }
        function toggleTradeGroup() {
            tradeGroup.style.display = notExchangeableSelect.checked ? 'none' : 'block';
        }
        notExchangeableSelect.addEventListener('change', toggleIsPriceRequired);
        notExchangeableSelect.addEventListener('change', toggleTradeGroup);
        toggleIsPriceRequired();
        toggleTradeGroup();
            </text>
        }

        @if (isForTrade && forTradeAcceptedTagIds.Any())
        {
            <text>
            var requiredTagIds = @Html.Raw("[" + string.Join(",", forTradeAcceptedTagIds) + "]");
            document.querySelectorAll('#tagSelectCreate option').forEach(function(opt) {
                if (requiredTagIds.includes(parseInt(opt.value))) {
                    opt.style.fontWeight = 'bold';
                    opt.textContent = opt.textContent + ' *';
                }
            });
            </text>
        }
    </script>
}
