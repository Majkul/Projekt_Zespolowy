@model ProjektZespolowyGr3.Models.ViewModels.CreateListingViewModel

@{
    ViewData["Title"] = "Dodaj ogłoszenie";
    var forTradeListingId = ViewBag.ForTradeListingId as int?;
    var forTradeTitle = ViewBag.ForTradeListingTitle as string;
    var forTradeAcceptedTagIds = ViewBag.ForTradeAcceptedTagIds as List<int> ?? new List<int>();
    var forTradeAcceptedTagNames = ViewBag.ForTradeAcceptedTagNames as List<string> ?? new List<string>();
    bool isForTrade = forTradeListingId.HasValue;
}

<div class="page-header mb-4">
    <h2 class="page-title">Dodaj nowe ogłoszenie</h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-8">
        @if (isForTrade)
        {
            <div class="alert alert-info d-flex align-items-start gap-2" role="alert">
                <i class="bi bi-lock fs-3"></i>
                <div>
                    <strong>Ogłoszenie prywatne pod wymianę</strong><br />
                    Tworzysz ofertę w kontekście ogłoszenia <strong>@forTradeTitle</strong>.
                    Będzie widoczne tylko w Twojej puli wymiany.
                    @if (forTradeAcceptedTagNames.Any())
                    {
                        <span>Wymagany co najmniej jeden z tagów: <strong>@string.Join(", ", forTradeAcceptedTagNames)</strong>.</span>
                    }
                </div>
            </div>
        }

        <div class="card">
            <div class="card-body">
                <form asp-action="Create" enctype="multipart/form-data">
                    @if (isForTrade)
                    {
                        <input type="hidden" name="forTradeListingId" value="@forTradeListingId" />
                    }

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                    }

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label required">Tytuł ogłoszenia</label>
                        <input asp-for="Title" class="form-control" placeholder="Np. Komputer gamingowy" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Opis</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Opisz szczegółowo swoją ofertę..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label for="tagSelectCreate" class="form-label">Kategorie</label>
                        <select asp-for="SelectedTagIds" asp-items="Model.AvailableTags" multiple class="form-select" id="tagSelectCreate"></select>
                        <span asp-validation-for="SelectedTagIds" class="text-danger small"></span>
                    </div>

                    @if (isForTrade)
                    {
                        <input type="hidden" name="NotExchangeable" value="false" />
                        <input type="hidden" name="IsPrivate" value="true" />
                        <input type="hidden" name="IsFeatured" value="false" />
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-check">
                                <input asp-for="NotExchangeable" class="form-check-input" id="not-exchangable-select" />
                                <span class="form-check-label">Nie do wymiany</span>
                            </label>
                        </div>
                    }

                    @if (!isForTrade)
                    {
                        <div class="card card-sm mb-3 border-info" id="trade-group">
                            <div class="card-header bg-info-lt">Wymiana</div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label asp-for="MinExchangeValue" class="form-label">Minimalna wartość oferty kupującego (PLN)</label>
                                    <input asp-for="MinExchangeValue" type="number" step="0.01" min="0" max="1000000" class="form-control" />
                                    <small class="form-hint">Pusta wartość = brak progu.</small>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="ExchangeDescription" class="form-label">Czego szukasz w zamian</label>
                                    <textarea asp-for="ExchangeDescription" class="form-control" rows="3" placeholder="Np. interesują mnie tylko książki fantasy…"></textarea>
                                </div>
                                <div class="mb-0">
                                    <label for="tagSelectCreateExchange" class="form-label">Akceptowane tagi przy wymianie</label>
                                    <select asp-for="SelectedExchangeAcceptedTagIds" asp-items="Model.AvailableTags" multiple class="form-select" id="tagSelectCreateExchange"></select>
                                    <small class="form-hint">Jeśli nic nie wybierzesz - dowolne kategorie.</small>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="mb-3" id="price-group">
                        <label asp-for="Price" class="form-label" id="price-label">Cena (PLN)</label>
                        <input asp-for="Price" type="number" step="0.01" min="0" max="1000000" class="form-control" placeholder="0.00" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="StockQuantity" class="form-label required">Liczba sztuk</label>
                        <input asp-for="StockQuantity" type="number" min="1" class="form-control" />
                        <small class="form-hint">Ile identycznych przedmiotów sprzedajesz / wystawiasz do wymiany w tym ogłoszeniu.</small>
                        <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhotoFiles" class="form-label">Zdjęcia (maksymalnie 5)</label>
                        <div class="image-upload-container">
                            <input asp-for="PhotoFiles" type="file" multiple accept=".jpg,.jpeg,.png" class="form-control image-upload-input" />
                        </div>
                        <small class="form-hint">Pierwsze zdjęcie będzie zdjęciem głównym. Możesz przesłać maksymalnie 5 zdjęć.</small>
                        <span asp-validation-for="PhotoFiles" class="text-danger small"></span>
                    </div>

                    @if (!isForTrade)
                    {
                        <div class="mb-2">
                            <label class="form-check">
                                <input asp-for="IsFeatured" class="form-check-input" />
                                <span class="form-check-label">Wyróżnij na profilu</span>
                            </label>
                        </div>
                        <div class="mb-3">
                            <label class="form-check">
                                <input asp-for="IsPrivate" class="form-check-input" />
                                <span class="form-check-label">Ogłoszenie prywatne</span>
                            </label>
                        </div>
                    }

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
                        <button type="submit" class="btn btn-primary">Utwórz ogłoszenie</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        @if (!isForTrade)
        {
            <text>
        const notExchangeableSelect = document.getElementById('not-exchangable-select');
        const priceLabel = document.getElementById('price-label');
        const tradeGroup = document.getElementById('trade-group');

        function toggleIsPriceRequired() {
            priceLabel.textContent = "Cena (PLN)" + (notExchangeableSelect.checked ? " *" : "");
        }
        function toggleTradeGroup() {
            const disabled = notExchangeableSelect.checked;
            tradeGroup.style.display = disabled ? 'none' : 'block';
            tradeGroup.querySelectorAll('input, textarea, select').forEach(function (input) {
                input.disabled = disabled;
                if (disabled) {
                    if (input.multiple) {
                        Array.from(input.options).forEach(option => option.selected = false);
                    } else {
                        input.value = '';
                    }
                }
            });
        }
        notExchangeableSelect.addEventListener('change', toggleIsPriceRequired);
        notExchangeableSelect.addEventListener('change', toggleTradeGroup);
        toggleIsPriceRequired();
        toggleTradeGroup();
            </text>
        }

        @if (isForTrade && forTradeAcceptedTagIds.Any())
        {
            <text>
            var requiredTagIds = @Html.Raw("[" + string.Join(",", forTradeAcceptedTagIds) + "]");
            document.querySelectorAll('#tagSelectCreate option').forEach(function(opt) {
                if (requiredTagIds.includes(parseInt(opt.value))) {
                    opt.style.fontWeight = 'bold';
                    opt.textContent = opt.textContent + ' *';
                }
            });
            </text>
        }
    </script>
}
