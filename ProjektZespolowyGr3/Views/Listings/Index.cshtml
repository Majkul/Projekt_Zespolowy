@model IEnumerable<ProjektZespolowyGr3.Models.ViewModels.BrowseListingsViewModel>

@{
    ViewData["Title"] = "Oferty";
    var searchString = ViewBag.SearchString as string ?? "";
    var noResultsMsg = ViewBag.NoResultsMessage as string;
    var selectedTags = ViewBag.TagIds as List<int> ?? new List<int>();
    var minPrice = ViewBag.MinPrice as decimal?;
    var maxPrice = ViewBag.MaxPrice as decimal?;
    var listingType = ViewBag.ListingType as string ?? "";
    var sortBy = ViewBag.SortBy as string ?? "newest";
    var maxDistanceKm = ViewBag.MaxDistanceKm as int?;
    var userLat = ViewBag.UserLat as double?;
    var userLng = ViewBag.UserLng as double?;
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? Model.Count();
    var pageSize = ViewBag.PageSize as int? ?? 24;
    var mobileFilterViewData = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        ["TagSelectId"] = "tagSelectFilterMobile"
    };
    var desktopFilterViewData = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        ["TagSelectId"] = "tagSelectFilterDesktop"
    };

    string? FormatQueryValue(object? value)
    {
        return value switch
        {
            null => null,
            decimal decimalValue => decimalValue.ToString(System.Globalization.CultureInfo.InvariantCulture),
            double doubleValue => doubleValue.ToString(System.Globalization.CultureInfo.InvariantCulture),
            _ => value.ToString()
        };
    }

    void AddQueryValue(List<KeyValuePair<string, string?>> query, string key, object? value)
    {
        var formattedValue = FormatQueryValue(value);
        if (!string.IsNullOrWhiteSpace(formattedValue))
        {
            query.Add(new KeyValuePair<string, string?>(key, formattedValue));
        }
    }

    string PageUrl(int pageNumber)
    {
        var query = new List<KeyValuePair<string, string?>>
        {
            new("page", pageNumber.ToString(System.Globalization.CultureInfo.InvariantCulture)),
            new("pageSize", pageSize.ToString(System.Globalization.CultureInfo.InvariantCulture))
        };

        AddQueryValue(query, "searchString", searchString);
        foreach (var tagId in selectedTags)
        {
            query.Add(new KeyValuePair<string, string?>("tagIds", tagId.ToString(System.Globalization.CultureInfo.InvariantCulture)));
        }
        AddQueryValue(query, "minPrice", minPrice);
        AddQueryValue(query, "maxPrice", maxPrice);
        AddQueryValue(query, "listingType", listingType);
        AddQueryValue(query, "sortBy", sortBy);
        AddQueryValue(query, "maxDistanceKm", maxDistanceKm);
        AddQueryValue(query, "userLat", userLat);
        AddQueryValue(query, "userLng", userLng);

        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
            Url.Action("Index", "Listings") ?? "",
            query);
    }
}

