@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("filterForm");
            const distanceInput = document.querySelector('input[name="maxDistanceKm"]');
            const userLatInput = document.getElementById("userLat");
            const userLngInput = document.getElementById("userLng");

            form.addEventListener("submit", function (e) {
                const maxDistanceValue = distanceInput.value;

                if (maxDistanceValue && (!userLatInput.value || !userLngInput.value)) {
                    e.preventDefault();

                    if (!navigator.geolocation) {
                        userLatInput.value = "";
                        userLngInput.value = "";

                        form.submit();
                        return;
                    }

                    navigator.geolocation.getCurrentPosition(
                        function (position) {
                            userLatInput.value = position.coords.latitude;
                            userLngInput.value = position.coords.longitude;
                            form.submit();
                        },
                        function (error) {
                            console.warn(error);
                            userLatInput.value = "";
                            userLngInput.value = "";
                            form.submit();
                        }
                    );
                }
            });
        });
    </script>
}
