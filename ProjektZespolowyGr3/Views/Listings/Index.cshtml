@model IEnumerable<ProjektZespolowyGr3.Models.ViewModels.BrowseListingsViewModel>

@{
    ViewData["Title"] = "Oferty";
    var searchString = ViewBag.SearchString as string;
    var noResultsMessage = ViewBag.NoResultsMessage as string;
}

<div class="container mt-4">
    <h2>Oferty</h2>

    <form method="get" class="mb-4">
        <div class="input-group">
            <input type="text"
                   name="searchString"
                   class="form-control"
                   placeholder="Szukaj ofert..."
                   value="@(searchString ?? string.Empty)" />
            <button class="btn btn-primary" type="submit">Szukaj</button>
        </div>
    </form>

    @if (!string.IsNullOrEmpty(noResultsMessage))
    {
        <div class="alert alert-info">
            @noResultsMessage
        </div>
    }

    <div class="row">
        @foreach (var browseListing in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="row g-0">
                        <div class="col-md-4">
                            @if (!string.IsNullOrEmpty(browseListing.PhotoUrl))
                            {
                                <img src="@browseListing.PhotoUrl" class="img-fluid rounded-start" alt="@browseListing.Listing.Title" style="height: 100%; object-fit: cover;">
                            }
                            else
                            {
                                <div class="bg-secondary d-flex align-items-center justify-content-center h-100">
                                    <span class="text-white">Brak zdjęcia</span>
                                </div>
                            }
                        </div>
                        <div class="col-md-8">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">
                                    <a href="@Url.Action("Details", "Listings", new { id = browseListing.ListingId })" class="text-decoration-none text-dark">
                                        @browseListing.Listing.Title
                                    </a>
                                </h5>
                                @if (!string.IsNullOrEmpty(browseListing.Listing.Description))
                                {
                                    <p class="card-text text-muted small">@(browseListing.Listing.Description.Length > 100 ? browseListing.Listing.Description.Substring(0, 100) + "..." : browseListing.Listing.Description)</p>
                                }
                                <div class="mt-auto">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        @if (browseListing.Listing.Price.HasValue)
                                        {
                                            <strong class="text-primary fs-5">@browseListing.Listing.Price.Value.ToString("C")</strong>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info">Wymiana</span>
                                        }
                                        @if (browseListing.ReviewCount > 0)
                                        {
                                            <small class="text-muted">⭐ @browseListing.AverageRating.ToString("0.0") (@browseListing.ReviewCount)</small>
                                        }
                                    </div>
                                    <div class="d-flex gap-2">
                                        <a href="@Url.Action("Details", "Listings", new { id = browseListing.ListingId })" class="btn btn-primary btn-sm flex-grow-1">Zobacz szczegóły</a>
                                        <a asp-controller="Tickets" asp-action="ReportListing" asp-route-listingId="@browseListing.ListingId" class="btn btn-outline-danger btn-sm">Zgłoś</a>
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer bg-white">
                                <small class="text-muted">
                                    Sprzedawca: <a asp-controller="UserProfile" asp-action="Details" asp-route-id="@browseListing.SellerId" class="text-decoration-none">@browseListing.Seller?.Username</a>
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.Any())
    {
        <hr />
    }
</div>