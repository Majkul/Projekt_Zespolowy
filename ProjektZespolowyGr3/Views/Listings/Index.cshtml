@model ProjektZespolowyGr3.Models.ViewModels.ListingsFilterViewModel

@{
    ViewData["Title"] = "Oferty";
}

<div class="container mt-4">
    <h2 class="mb-4">Oferty</h2>

    <form method="get" id="filterForm">
        <div class="row g-4">

            <!-- ── Sidebar ── -->
            <div class="col-lg-3">
                <div class="card shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong>Filtry</strong>
                        @if (Model.HasActiveFilters)
                        {
                            <a href="@Url.Action("Index", "Listings")" class="btn btn-sm btn-outline-secondary">Wyczyść</a>
                        }
                    </div>
                    <div class="card-body">

                        <!-- Search -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Szukaj</label>
                            <input type="text"
                                   name="searchString"
                                   class="form-control"
                                   placeholder="Tytuł lub opis..."
                                   value="@(Model.SearchString ?? string.Empty)" />
                        </div>

                        <!-- Type -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Typ ogłoszenia</label>
                            <div class="d-flex flex-column gap-1">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="type" id="typeAll"
                                           value="" @(string.IsNullOrEmpty(Model.Type) ? "checked" : "") />
                                    <label class="form-check-label" for="typeAll">Wszystkie</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="type" id="typeSale"
                                           value="Sale" @(Model.Type == "Sale" ? "checked" : "") />
                                    <label class="form-check-label" for="typeSale">Sprzedaż</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="type" id="typeTrade"
                                           value="Trade" @(Model.Type == "Trade" ? "checked" : "") />
                                    <label class="form-check-label" for="typeTrade">Wymiana</label>
                                </div>
                            </div>
                        </div>

                        <!-- Price range -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Cena (zł)</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="number" name="minPrice" class="form-control form-control-sm"
                                           placeholder="Od" min="0" step="0.01"
                                           value="@(Model.MinPrice?.ToString() ?? "")" />
                                </div>
                                <div class="col-6">
                                    <input type="number" name="maxPrice" class="form-control form-control-sm"
                                           placeholder="Do" min="0" step="0.01"
                                           value="@(Model.MaxPrice?.ToString() ?? "")" />
                                </div>
                            </div>
                        </div>

                        <!-- Tags -->
                        @if (Model.AvailableTags.Any())
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Kategorie</label>
                                <div class="d-flex flex-column gap-1" style="max-height: 200px; overflow-y: auto;">
                                    @foreach (var tag in Model.AvailableTags)
                                    {
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox"
                                                   name="selectedTagIds" value="@tag.Id"
                                                   id="tag_@tag.Id"
                                                   @(Model.SelectedTagIds.Contains(tag.Id) ? "checked" : "") />
                                            <label class="form-check-label" for="tag_@tag.Id">@tag.Name</label>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Sort -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Sortuj według</label>
                            <select name="sortBy" id="sortBySelect" class="form-select form-select-sm">
                                <option value="">Najnowsze</option>
                                <option value="oldest">Najstarsze</option>
                                <option value="price_asc">Cena rosnąco</option>
                                <option value="price_desc">Cena malejąco</option>
                                <option value="most_viewed">Najpopularniejsze</option>
                            </select>
                            <script>document.getElementById('sortBySelect').value = '@(Model.SortBy ?? "")';</script>
                        </div>

                        <button class="btn btn-primary w-100" type="submit">Zastosuj filtry</button>
                    </div>
                </div>
            </div>

            <!-- ── Results ── -->
            <div class="col-lg-9">

                @if (Model.HasActiveFilters)
                {
                    <div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
                        <span class="text-muted small">Aktywne filtry:</span>
                        @if (!string.IsNullOrWhiteSpace(Model.SearchString))
                        {
                            <span class="badge bg-secondary">Szukaj: @Model.SearchString</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Type))
                        {
                            <span class="badge bg-secondary">@(Model.Type == "Sale" ? "Sprzedaż" : "Wymiana")</span>
                        }
                        @if (Model.MinPrice.HasValue)
                        {
                            <span class="badge bg-secondary">Od @Model.MinPrice zł</span>
                        }
                        @if (Model.MaxPrice.HasValue)
                        {
                            <span class="badge bg-secondary">Do @Model.MaxPrice zł</span>
                        }
                        @foreach (var tagId in Model.SelectedTagIds)
                        {
                            var tag = Model.AvailableTags.FirstOrDefault(t => t.Id == tagId);
                            if (tag != null)
                            {
                                <span class="badge bg-secondary">@tag.Name</span>
                            }
                        }
                    </div>
                }

                @if (Model.FeaturedResults.Any())
                {
                    <div class="mb-4">
                        <h5 class="text-warning fw-bold mb-3">
                            <span class="me-1">★</span> Wyróżnione oferty
                        </h5>
                        <div class="row">
                            @foreach (var item in Model.FeaturedResults)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="card h-100 shadow border border-warning border-2">
                                        <div class="row g-0">
                                            <div class="col-4">
                                                @if (!string.IsNullOrEmpty(item.PhotoUrl))
                                                {
                                                    <img src="@item.PhotoUrl" class="img-fluid rounded-start h-100" alt="@item.Listing.Title" style="object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <div class="bg-warning bg-opacity-25 rounded-start d-flex align-items-center justify-content-center h-100">
                                                        <span class="text-warning fs-4">★</span>
                                                    </div>
                                                }
                                            </div>
                                            <div class="col-8">
                                                <div class="card-body d-flex flex-column py-2 px-3">
                                                    <div class="d-flex align-items-center gap-1 mb-1">
                                                        <span class="badge bg-warning text-dark" style="font-size: 0.7rem;">★ Wyróżnione</span>
                                                    </div>
                                                    <h6 class="card-title mb-1">
                                                        <a href="@Url.Action("Details", "Listings", new { id = item.ListingId })" class="text-decoration-none text-dark stretched-link">
                                                            @item.Listing.Title
                                                        </a>
                                                    </h6>
                                                    @if (!string.IsNullOrEmpty(item.Listing.Description))
                                                    {
                                                        <p class="card-text text-muted small mb-1" style="font-size: 0.8rem;">
                                                            @(item.Listing.Description.Length > 80 ? item.Listing.Description.Substring(0, 80) + "…" : item.Listing.Description)
                                                        </p>
                                                    }
                                                    <div class="mt-auto d-flex justify-content-between align-items-center">
                                                        @if (item.Listing.Price.HasValue)
                                                        {
                                                            <strong class="text-primary">@item.Listing.Price.Value.ToString("C")</strong>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-info">Wymiana</span>
                                                        }
                                                        <small class="text-muted" style="font-size: 0.75rem;">👁 @item.Listing.ViewCount</small>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <hr class="border-warning" />
                    </div>
                }

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted small">Znaleziono: <strong>@(Model.Results.Count() + Model.FeaturedResults.Count())</strong> ofert</span>
                </div>

                @if (!Model.Results.Any() && !Model.FeaturedResults.Any())
                {
                    <div class="alert alert-info">
                        Nie znaleziono ofert pasujących do wybranych kryteriów.
                        @if (Model.HasActiveFilters)
                        {
                            <a href="@Url.Action("Index", "Listings")" class="alert-link">Wyczyść filtry</a>
                        }
                    </div>
                }
                else
                {
                    <div class="row">
                        @foreach (var item in Model.Results)
                        {
                            <div class="col-md-6 mb-4">
                                <div class="card h-100 shadow-sm">
                                    <div class="row g-0">
                                        <div class="col-4">
                                            @if (!string.IsNullOrEmpty(item.PhotoUrl))
                                            {
                                                <img src="@item.PhotoUrl"
                                                     class="img-fluid rounded-start h-100"
                                                     alt="@item.Listing.Title"
                                                     style="object-fit: cover;" />
                                            }
                                            else
                                            {
                                                <div class="bg-secondary rounded-start d-flex align-items-center justify-content-center h-100">
                                                    <span class="text-white small">Brak<br/>zdjęcia</span>
                                                </div>
                                            }
                                        </div>
                                        <div class="col-8">
                                            <div class="card-body d-flex flex-column py-2 px-3">
                                                <h6 class="card-title mb-1">
                                                    <a href="@Url.Action("Details", "Listings", new { id = item.ListingId })"
                                                       class="text-decoration-none text-dark stretched-link">
                                                        @item.Listing.Title
                                                    </a>
                                                </h6>
                                                @if (!string.IsNullOrEmpty(item.Listing.Description))
                                                {
                                                    <p class="card-text text-muted small mb-1" style="font-size: 0.8rem;">
                                                        @(item.Listing.Description.Length > 80 ? item.Listing.Description.Substring(0, 80) + "…" : item.Listing.Description)
                                                    </p>
                                                }
                                                @{
                                                    var tags = item.Listing.Tags?.Select(t => t.Tag?.Name).Where(n => n != null).Take(3).ToList();
                                                }
                                                @if (tags != null && tags.Any())
                                                {
                                                    <div class="mb-1">
                                                        @foreach (var tagName in tags)
                                                        {
                                                            <span class="badge bg-light text-dark border" style="font-size: 0.7rem;">@tagName</span>
                                                        }
                                                    </div>
                                                }
                                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                                    @if (item.Listing.Price.HasValue)
                                                    {
                                                        <strong class="text-primary">@item.Listing.Price.Value.ToString("C")</strong>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-info">Wymiana</span>
                                                    }
                                                    @if (item.ReviewCount > 0)
                                                    {
                                                        <small class="text-muted">⭐ @item.AverageRating.ToString("0.0")</small>
                                                    }
                                                </div>
                                                <div class="mt-1">
                                                    <small class="text-muted" style="font-size: 0.75rem;">
                                                        👁 @item.Listing.ViewCount &nbsp;|&nbsp;
                                                        <a asp-controller="UserProfile" asp-action="Details"
                                                           asp-route-id="@item.SellerId"
                                                           class="text-decoration-none text-muted">@item.Seller?.Username</a>
                                                    </small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </form>
</div>
