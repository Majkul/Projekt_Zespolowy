@model IEnumerable<ProjektZespolowyGr3.Models.ViewModels.BrowseListingsViewModel>
@using ProjektZespolowyGr3.Models.DbModels

@{
    var searchString = ViewBag.SearchString as string ?? "";
    var allTags = ViewBag.AllTags as List<Tag> ?? new List<Tag>();
    var selectedTags = ViewBag.TagIds as List<int> ?? new List<int>();
    var minPrice = ViewBag.MinPrice as decimal?;
    var maxPrice = ViewBag.MaxPrice as decimal?;
    var listingType = ViewBag.ListingType as string ?? "";
    var sortBy = ViewBag.SortBy as string ?? "newest";
    var maxDistanceKm = ViewBag.MaxDistanceKm as int?;
    var userLat = ViewBag.UserLat as double?;
    var userLng = ViewBag.UserLng as double?;
    var pageSize = ViewBag.PageSize as int? ?? 24;
    var tagSelectId = ViewData["TagSelectId"] as string ?? "tagSelectFilter";
    var allTypeId = $"{tagSelectId}-type-all";
    var saleTypeId = $"{tagSelectId}-type-sale";
    var tradeTypeId = $"{tagSelectId}-type-trade";
    var locationButtonId = $"{tagSelectId}-location-button";
    var locationFeedbackId = $"{tagSelectId}-location-feedback";
}

<form method="get">
    <div class="card filter-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <div class="text-uppercase small text-muted fw-bold">Dopasuj wyniki</div>
                <div class="fw-semibold">Filtry</div>
            </div>
            <a href="@Url.Action("Index", "Listings")" class="btn btn-link btn-sm p-0 text-secondary">Wyczyść</a>
        </div>
        <div class="card-body">
            <input type="hidden" name="searchString" value="@searchString" />
            <input type="hidden" name="pageSize" value="@pageSize" />

            <div class="mb-4">
                <label class="form-label fw-semibold small text-uppercase text-muted">Typ oferty</label>
                <div class="filter-chip-group">
                    <input class="btn-check" id="@allTypeId" type="radio" name="listingType"
                           value="" @(listingType == "" ? "checked" : "") />
                    <label class="filter-chip" for="@allTypeId">
                        <span>Wszystkie</span>
                        <i class="bi bi-grid"></i>
                    </label>

                    <input class="btn-check" id="@saleTypeId" type="radio" name="listingType"
                           value="sale" @(listingType == "sale" ? "checked" : "") />
                    <label class="filter-chip" for="@saleTypeId">
                        <span>Sprzedaż</span>
                        <i class="bi bi-cash-coin"></i>
                    </label>

                    <input class="btn-check" id="@tradeTypeId" type="radio" name="listingType"
                           value="trade" @(listingType == "trade" ? "checked" : "") />
                    <label class="filter-chip" for="@tradeTypeId">
                        <span>Wymiana</span>
                        <i class="bi bi-arrow-left-right"></i>
                    </label>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold small text-uppercase text-muted">Cena</label>
                <div class="row g-2">
                    <div class="col-6">
                        <div class="input-group input-group-sm">
                            <input type="number" name="minPrice" class="form-control"
                                   placeholder="Od" min="0" step="0.01"
                                   value="@(minPrice.HasValue ? minPrice.Value.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) : "")" />
                            <span class="input-group-text">PLN</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="input-group input-group-sm">
                            <input type="number" name="maxPrice" class="form-control"
                                   placeholder="Do" min="0" step="0.01"
                                   value="@(maxPrice.HasValue ? maxPrice.Value.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) : "")" />
                            <span class="input-group-text">PLN</span>
                        </div>
                    </div>
                </div>
            </div>

            @if (allTags.Any())
            {
                <div class="mb-4">
                    <label for="@tagSelectId" class="form-label fw-semibold small text-uppercase text-muted">Kategorie</label>
                    <select name="tagIds" id="@tagSelectId" multiple class="form-select form-select-sm">
                        @foreach (var tag in allTags)
                        {
                            <option value="@tag.Id" selected="@(selectedTags.Contains(tag.Id) ? "selected" : null)">@tag.Name</option>
                        }
                    </select>
                </div>
            }

            <div class="mb-4">
                <label class="form-label fw-semibold small text-uppercase text-muted">Sortuj</label>
                <select name="sortBy" class="form-select form-select-sm">
                    <option value="newest" selected="@(sortBy == "newest" ? "selected" : null)">Najnowsze</option>
                    <option value="price_asc" selected="@(sortBy == "price_asc" ? "selected" : null)">Cena: rosnąco</option>
                    <option value="price_desc" selected="@(sortBy == "price_desc" ? "selected" : null)">Cena: malejąco</option>
                    <option value="views" selected="@(sortBy == "views" ? "selected" : null)">Najpopularniejsze</option>
                    <option value="rating" selected="@(sortBy == "rating" ? "selected" : null)">Najlepiej oceniane</option>
                </select>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold small text-uppercase text-muted">
                    Maksymalna odległość (km)
                </label>

                <input type="number"
                       name="maxDistanceKm"
                       class="form-control form-control-sm"
                       min="1"
                       step="1"
                       placeholder="np. 25"
                       value="@(maxDistanceKm.HasValue ? maxDistanceKm.Value.ToString() : "")" />

                <button type="button"
                        id="@locationButtonId"
                        class="btn btn-outline-secondary btn-sm w-100 mt-2">
                    <i class="bi bi-geo-alt me-1"></i> Użyj mojej lokalizacji
                </button>

                <div id="@locationFeedbackId" class="location-feedback mt-2 small text-muted">
                    @if (userLat.HasValue && userLng.HasValue)
                    {
                        <text>Lokalizacja jest ustawiona.</text>
                    }
                    else
                    {
                        <text>Najpierw użyj swojej lokalizacji, aby filtrować po odległości.</text>
                    }
                </div>
            </div>

            <input type="hidden" name="userLat"
                   value="@(userLat.HasValue ? userLat.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "")" />
            <input type="hidden" name="userLng"
                   value="@(userLng.HasValue ? userLng.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "")" />

            <button type="submit" class="btn btn-primary w-100">Zastosuj filtry</button>
        </div>
    </div>
</form>

<script>
    (() => {
        const form = document.getElementById('@locationButtonId')?.closest('form');
        const button = document.getElementById('@locationButtonId');
        const feedback = document.getElementById('@locationFeedbackId');
        const distanceInput = form?.querySelector('input[name="maxDistanceKm"]');
        const latInput = form?.querySelector('input[name="userLat"]');
        const lngInput = form?.querySelector('input[name="userLng"]');

        function setFeedback(message, isError = false) {
            if (!feedback) return;
            feedback.textContent = message;
            feedback.classList.toggle('text-danger', isError);
            feedback.classList.toggle('text-muted', !isError);
        }

        button?.addEventListener('click', () => {
            if (!navigator.geolocation) {
                setFeedback('Nie można określić lokalizacji.', true);
                return;
            }

            setFeedback('Pobieram lokalizację...');
            navigator.geolocation.getCurrentPosition(
                position => {
                    if (latInput) latInput.value = position.coords.latitude.toString();
                    if (lngInput) lngInput.value = position.coords.longitude.toString();
                    setFeedback('Lokalizacja jest ustawiona.');
                },
                () => setFeedback('Nie można określić lokalizacji.', true)
            );
        });

        form?.addEventListener('submit', event => {
            if (distanceInput?.value && (!latInput?.value || !lngInput?.value)) {
                event.preventDefault();
                setFeedback('Najpierw użyj swojej lokalizacji, aby filtrować po odległości.', false);
            }
        });
    })();
</script>
