@using ProjektZespolowyGr3.Models.DbModels
@model Listing

@{
    ViewData["Title"] = "Szczegóły ogłoszenia";
    bool isUserAuthenticated = User.Identity?.IsAuthenticated == true;
    bool isUserSeller = isUserAuthenticated && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == Model.SellerId.ToString();
    bool isSaleOffer = Model.Price.HasValue;
    var currentReturnUrl = Context.Request.Path.ToString() + Context.Request.QueryString.ToString();
    var activePhotoId = Model.Photos?.FirstOrDefault(p => p.IsFeatured)?.Id ?? Model.Photos?.FirstOrDefault()?.Id;
    bool canReview = ViewBag.CanReview as bool? ?? false;
    bool hasReviewed = ViewBag.HasReviewed as bool? ?? false;
}

@if (TempData["TradeError"] != null)
{
    <div class="alert alert-warning" role="alert">@TempData["TradeError"]</div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="page-header mb-3">
            <h2 class="page-title text-break-anywhere">
                @Model.Title
                @if (Model.IsPrivate && isUserSeller)
                {
                    <span class="badge bg-secondary-lt ms-2"><i class="bi bi-lock me-1"></i>Prywatne</span>
                }
            </h2>
        </div>

        @if (Model.Photos != null && Model.Photos.Any())
        {
            <div class="card mb-4">
                <div id="photoCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @foreach (var photo in Model.Photos)
                        {
                            <div class="carousel-item @(photo.Id == activePhotoId ? "active" : "")">
                                <img src="@photo.Upload.Url" class="d-block w-100" alt="@Model.Title" style="max-height: 500px; object-fit: contain; background: #f8f9fa;">
                            </div>
                        }
                    </div>
                    @if (Model.Photos.Count() > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#photoCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Poprzednie</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#photoCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Następne</span>
                        </button>
                    }
                </div>
            </div>
        }

        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Opis</h3>
            </div>
            <div class="card-body">
                <p class="mb-0">@(string.IsNullOrEmpty(Model.Description) ? "Brak opisu." : Model.Description)</p>
            </div>
        </div>

        @if (Model.Tags != null && Model.Tags.Any())
        {
            <div class="mb-4">
                <h4>Tagi</h4>
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var tag in Model.Tags)
                    {
                        <span class="badge bg-blue-lt">@tag.Tag.Name</span>
                    }
                </div>
            </div>
        }

        @if (!Model.NotExchangeable && (Model.ExchangeDescription != null || (Model.ExchangeAcceptedTags != null && Model.ExchangeAcceptedTags.Any()) || Model.MinExchangeValue.HasValue))
        {
            <div class="card mb-4">
                <div class="card-status-start bg-info"></div>
                <div class="card-header"><h3 class="card-title">Wymiana</h3></div>
                <div class="card-body">
                    @if (Model.MinExchangeValue.HasValue)
                    {
                        <p class="mb-2"><strong>Minimalna wartość oferty kupującego:</strong> @Model.MinExchangeValue.FormatPricePLN()</p>
                    }
                    @if (Model.ExchangeAcceptedTags != null && Model.ExchangeAcceptedTags.Any())
                    {
                        <p class="mb-1"><strong>Akceptowane tagi przy wymianie:</strong></p>
                        <div class="mb-2 d-flex flex-wrap gap-1">
                            @foreach (var et in Model.ExchangeAcceptedTags)
                            {
                                <span class="badge bg-azure-lt">@et.Tag.Name</span>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.ExchangeDescription))
                    {
                        <p class="mb-0"><strong>Czego szukam w zamian:</strong> @Model.ExchangeDescription</p>
                    }
                </div>
            </div>
        }
        else if (Model.NotExchangeable)
        {
            <p class="text-secondary"><span class="badge bg-dark me-1">Nie do wymiany</span> To ogłoszenie nie jest uwzględniane w propozycjach wymiany.</p>
        }

        <div class="card mb-4">
            <div class="card-header"><h3 class="card-title">Opinie</h3></div>
            <div class="card-body">
                @if (canReview)
                {
                    <a asp-controller="Reviews" asp-action="Create" asp-route-listingId="@Model.Id" class="btn btn-primary btn-sm mb-3"><i class="bi bi-star me-1"></i>Dodaj opinię</a>
                }
                else if (!isUserSeller && hasReviewed)
                {
                    <p class="text-secondary small mb-3">Już dodałeś opinię do tego ogłoszenia.</p>
                }

                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="border-bottom pb-3 mb-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h4 class="h6 mb-0">
                                        <a asp-controller="UserProfile" asp-action="Details" asp-route-username="@review.Reviewer.Username" class="text-decoration-none">
                                            @review.Reviewer.Username
                                        </a>
                                    </h4>
                                    <small class="text-secondary">@review.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                                </div>
                                <div class="text-warning">
                                    @for (int i = 0; i < review.Rating; i++)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(review.Description))
                            {
                                <p class="mb-2">@review.Description</p>
                            }
                            @if (review.Photos != null && review.Photos.Any())
                            {
                                <div class="d-flex gap-2 flex-wrap">
                                    @foreach (var photo in review.Photos)
                                    {
                                        <img src="@photo.Upload.Url" alt="Zdjęcie z opinii" class="rounded border" style="width: 100px; height: 100px; object-fit: cover;">
                                    }
                                </div>
                            }
                            @if (!isUserSeller && isUserAuthenticated)
                            {
                                <div class="mt-2">
                                    <a asp-controller="Tickets" asp-action="ReportReview" asp-route-reviewId="@review.Id" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-flag me-1"></i>Zgłoś opinię
                                    </a>
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <p class="text-secondary mb-0">Brak opinii. @(!isUserSeller ? "Bądź pierwszy!" : "")</p>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card sticky-top" style="top: 5.5rem;">
            <div class="card-body">
                <h3 class="card-title">Szczegóły</h3>
                @if (Model.IsArchived)
                {
                    <div class="alert alert-secondary"><strong>Ogłoszenie zarchiwizowane</strong></div>
                }

                @if (Model.Price.HasValue)
                {
                    <div class="mb-3">
                        <div class="text-secondary small">Cena</div>
                        <div class="@(Model.IsArchived ? "text-secondary" : "text-primary") fw-bold fs-2">@Model.Price.FormatPricePLN()</div>
                    </div>
                }

                <div class="datagrid mb-3">
                    <div class="datagrid-item">
                        <div class="datagrid-title">Dostępna ilość</div>
                        <div class="datagrid-content @(Model.StockQuantity > 0 ? "" : "text-danger")">@Model.StockQuantity szt.</div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">Sprzedawca</div>
                        <div class="datagrid-content">
                            <a asp-controller="UserProfile" asp-action="Details" asp-route-username="@Model.Seller.Username" class="text-decoration-none">
                                @Model.Seller.Username
                            </a>
                        </div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">Data utworzenia</div>
                        <div class="datagrid-content text-secondary">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">Liczba wyświetleń</div>
                        <div class="datagrid-content text-secondary">@Model.ViewCount</div>
                    </div>
                </div>

                @if (!Model.IsArchived && !isUserSeller)
                {
                    <div class="d-grid gap-2 mb-2">
                        <a asp-controller="Messages" asp-action="Conversation" asp-route-userId="@Model.SellerId" asp-route-listingId="@Model.Id" class="btn btn-outline-primary">
                            <i class="bi bi-envelope me-1"></i>Skontaktuj się ze sprzedawcą
                        </a>
                        @if (isUserAuthenticated && !Model.NotExchangeable && !Model.IsSold && Model.StockQuantity > 0)
                        {
                            <a asp-controller="TradeProposals" asp-action="Compose" asp-route-listingId="@Model.Id" class="btn btn-success">
                                <i class="bi bi-arrow-left-right me-1"></i>Wymień się
                            </a>
                        }
                    </div>
                }

                <hr />

                @if (Model.IsArchived)
                {
                    <button class="btn btn-secondary w-100 btn-lg mb-2" disabled>Ogłoszenie niedostępne</button>
                }
                else if (Model.IsSold || Model.StockQuantity <= 0)
                {
                    <div class="alert alert-danger mb-2"><strong>Sprzedane</strong></div>
                }
                else if (isUserSeller)
                {
                    <div class="d-grid gap-2">
                        <a asp-controller="ListingManage" asp-action="EditListing" asp-route-id="@Model.Id" asp-route-returnUrl="@currentReturnUrl" class="btn btn-primary btn-lg">Edytuj</a>
                        <form asp-controller="ListingManage" asp-action="DeleteListing" asp-route-id="@Model.Id" asp-route-returnUrl="@currentReturnUrl" method="post" onsubmit="return confirm('Czy na pewno chcesz usunąć to ogłoszenie?');">
                            <button type="submit" class="btn btn-outline-danger w-100">Usuń</button>
                        </form>
                    </div>
                }
                else if (!Model.IsSold && Model.StockQuantity > 0 && isSaleOffer)
                {
                    <form asp-controller="Payment" asp-action="Buy" method="post" class="mb-2">
                        <input type="hidden" name="listingId" value="@Model.Id" />
                        @if (Model.StockQuantity > 1)
                        {
                            <div class="mb-2">
                                <label for="buy-quantity" class="form-label small mb-1">Ilość</label>
                                <input id="buy-quantity" name="quantity" type="number" class="form-control" value="1" min="1" max="@Model.StockQuantity" required />
                            </div>
                        }
                        else
                        {
                            <input type="hidden" name="quantity" value="1" />
                        }
                        <button type="submit" class="btn btn-primary w-100 btn-lg"><i class="bi bi-bag-check me-1"></i>Kup teraz</button>
                    </form>
                }

                @if (!isUserSeller)
                {
                    <a asp-controller="Tickets" asp-action="ReportListing" asp-route-listingId="@Model.Id" class="btn btn-outline-danger w-100 mt-2">
                        <i class="bi bi-flag me-1"></i>Zgłoś ogłoszenie
                    </a>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var listing = {
                id: '@Model.Id',
                title: '@Model.Title',
                slug: '@SlugHelper.GenerateSlug(Model.Title)',
                image: '@(Model.Photos?.FirstOrDefault()?.Upload?.Url ?? "")'
            };

            var listingHistory = JSON.parse(localStorage.getItem('listingHistory') || '[]');

            listingHistory = listingHistory.filter(l => l.id !== listing.id);
            listingHistory.unshift(listing);
            listingHistory = listingHistory.slice(0, 5);

            localStorage.setItem('listingHistory', JSON.stringify(listingHistory));
        })();
    </script>
}
