@using ProjektZespolowyGr3.Models.DbModels
@model Listing

@{
    ViewData["Title"] = "Szczegóły ogłoszenia";
}

@{
    bool isUserAuthenticated = User.Identity.IsAuthenticated;
    bool isUserSeller = isUserAuthenticated && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == Model.SellerId.ToString();
}

<div class="container mt-4">
    @if (Model.IsArchived)
    {
        <div class="alert alert-secondary d-flex align-items-center mb-3" role="alert">
            <strong>Ogłoszenie zarchiwizowane</strong>
            @if (Model.ArchivedAt.HasValue)
            {
                <span class="ms-2 text-muted small">(@Model.ArchivedAt.Value.ToString("dd.MM.yyyy HH:mm"))</span>
            }
        </div>
    }
    <div class="row">
        <div class="col-md-8">
            <h2 class="mb-3">@Model.Title</h2>

            @if (Model.Photos != null && Model.Photos.Any())
            {
                <div class="mb-4">
                    <div id="photoCarousel" class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            @foreach (var photo in Model.Photos)
                            {
                                <div class="carousel-item @(photo.IsFeatured ? "active" : "")">
                                    <img src="@photo.Upload.Url" class="d-block w-100" alt="@Model.Title" style="max-height: 500px; object-fit: contain; background: #f8f9fa;">
                                </div>
                            }
                        </div>
                        @if (Model.Photos.Count() > 1)
                        {
                            <button class="carousel-control-prev" type="button" data-bs-target="#photoCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Poprzednie</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#photoCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Następne</span>
                            </button>
                        }
                    </div>
                </div>
            }

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Opis</h5>
                </div>
                <div class="card-body">
                    <p class="mb-0">@(string.IsNullOrEmpty(Model.Description) ? "Brak opisu." : Model.Description)</p>
                </div>
            </div>

            @if (Model.Tags != null && Model.Tags.Any())
            {
                <div class="mb-4">
                    <h5>Tagi:</h5>
                    <div>
                        @foreach (var tag in Model.Tags)
                        {
                            <span class="badge bg-secondary me-2">@tag.Tag.Name</span>
                        }
                    </div>
                </div>
            }

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Opinie</h5>
                </div>
                <div class="card-body">
                    @if (User.Identity.IsAuthenticated && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value != Model.SellerId.ToString())
                    {
                        <a asp-controller="Reviews" asp-action="Create" asp-route-listingId="@Model.Id" class="btn btn-primary btn-sm mb-3">Dodaj opinię</a>
                    }

                    @if (Model.Reviews != null && Model.Reviews.Any())
                    {
                        @foreach (var review in Model.Reviews)
                        {
                            <div class="border-bottom pb-3 mb-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <h6 class="mb-0">
                                            <a asp-controller="UserProfile" asp-action="Details" asp-route-id="@review.ReviewerId" class="text-decoration-none">
                                                @review.Reviewer.Username
                                            </a>
                                        </h6>
                                        <small class="text-muted">@review.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                                    </div>
                                    <div>
                                        @for (int i = 0; i < review.Rating; i++)
                                        {
                                            <span class="text-warning">⭐</span>
                                        }
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(review.Description))
                                {
                                    <p class="mb-2">@review.Description</p>
                                }
                                @if (review.Photos != null && review.Photos.Any())
                                {
                                    <div class="d-flex gap-2 flex-wrap">
                                        @foreach (var photo in review.Photos)
                                        {
                                            <img src="@photo.Upload.Url" alt="Zdjęcie z opinii" class="img-thumbnail" style="max-width: 100px; max-height: 100px;">
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted mb-0">Brak opinii. @(!isUserSeller ? "Bądź pierwszy!" : "")</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm sticky-top" style="top: 20px;">
                <div class="card-body">
                    <h5 class="card-title">Szczegóły</h5>

                    @if (Model.IsArchived)
                    {
                        <div class="alert alert-secondary mb-2">
                            <strong>Ogłoszenie zarchiwizowane</strong>
                        </div>
                    }

                    <hr />

                    <div class="mb-3">
                        <strong>Cena:</strong>
                        @if (Model.Price.HasValue)
                        {
                            <span class="@(Model.IsArchived ? "text-muted fs-4" : "text-primary fs-4")">@Model.Price.Value.ToString("C")</span>
                        }
                        else
                        {
                            <span class="badge bg-@(Model.IsArchived ? "secondary" : "info")">Wymiana</span>
                        }
                    </div>

                    <div class="mb-3">
                        <strong>Typ:</strong>
                        <span class="badge bg-@(Model.IsArchived ? "secondary" : Model.Type == ListingType.Sale ? "success" : "info")">
                            @(Model.Type == ListingType.Sale ? "Sprzedaż" : "Wymiana")
                        </span>
                    </div>

                    <div class="mb-3">
                        <strong>Sprzedawca:</strong><br />
                        <a asp-controller="UserProfile" asp-action="Details" asp-route-id="@Model.SellerId" class="text-decoration-none">
                            @Model.Seller.Username
                        </a>
                        @if (!Model.IsArchived && !isUserSeller)
                        {
                            <div class="mt-2">
                                <a asp-controller="Messages"
                                asp-action="Conversation"
                                asp-route-userId="@Model.SellerId"
                                asp-route-listingId="@Model.Id"
                                class="btn btn-outline-primary btn-sm w-100">
                                    Skontaktuj się ze sprzedawcą
                                </a>
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <strong>Data utworzenia:</strong><br />
                        <small class="text-muted">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                    </div>

                    <hr />

                    @if (Model.IsArchived)
                    {
                        <button class="btn btn-secondary w-100 btn-lg mb-2" disabled>
                            Ogłoszenie niedostępne
                        </button>
                    }
                    else if (!Model.IsSold && Model.Type == ListingType.Sale)
                    {
                        <form asp-controller="Payment" asp-action="Buy" method="post" class="mb-2">
                            <input type="hidden" name="listingId" value="@Model.Id" />
                            <button type="submit" class="btn btn-primary w-100 btn-lg")>
                                Kup teraz
                            </button>
                        </form>
                    }
                    else if (Model.IsSold)
                    {
                        <div class="alert alert-danger mb-2">
                            <strong>Sprzedane</strong>
                        </div>
                    }
                    else if (isUserSeller)
                    {
                        <a asp-controller="ListingManage" asp-action="EditListing" asp-route-id="@Model.Id" class="btn btn-primary w-100 btn-lg">Edit</a>
                        <hr/>
                        <form asp-controller="ListingManage" asp-action="ArchiveListing" asp-route-id="@Model.Id" method="post" class="mb-2">
                            <button type="submit" class="btn @(Model.IsArchived ? "btn-outline-success" : "btn-outline-secondary") w-100">
                                @(Model.IsArchived ? "Przywróć ogłoszenie" : "Archiwizuj ogłoszenie")
                            </button>
                        </form>
                        <form asp-controller="ListingManage" asp-action="DeleteListing" asp-route-id="item.Listing.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this listing?');">
                            <button type="submit" class="btn btn-danger w-100 btn-lg">Delete</button>
                        </form>
                    }

                    @if (!isUserSeller)
                    {
                        <a asp-controller="Tickets" asp-action="ReportListing" asp-route-listingId="@Model.Id" class="btn btn-outline-danger w-100">
                            Zgłoś ogłoszenie
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>