@using ProjektZespolowyGr3.Models.DbModels
@model Listing

@{
    ViewData["Title"] = "Szczegóły ogłoszenia";
}

@{
    bool isUserAuthenticated = User.Identity?.IsAuthenticated == true;
    bool isUserSeller = isUserAuthenticated && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == Model.SellerId.ToString();
}

<div class="container mt-4">
    @if (TempData["TradeError"] != null)
    {
        <div class="alert alert-warning">@TempData["TradeError"]</div>
    }
    @if (Model.IsArchived)
    {
        <div class="alert alert-secondary d-flex align-items-center mb-3" role="alert">
            <strong>Ogłoszenie zarchiwizowane</strong>
            @if (Model.ArchivedAt.HasValue)
            {
                <span class="ms-2 text-muted small">(@Model.ArchivedAt.Value.ToString("dd.MM.yyyy HH:mm"))</span>
            }
        </div>
    }
    <div class="row">
        <div class="col-md-8">
            <h2 class="mb-3">@Model.Title</h2>

            @if (Model.Photos != null && Model.Photos.Any())
            {
                <div class="mb-4">
                    <div id="photoCarousel" class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            @foreach (var photo in Model.Photos)
                            {
                                <div class="carousel-item @(photo.IsFeatured ? "active" : "")">
                                    <img src="@photo.Upload.Url" class="d-block w-100" alt="@Model.Title" style="max-height: 500px; object-fit: contain; background: #f8f9fa;">
                                </div>
                            }
                        </div>
                        @if (Model.Photos.Count() > 1)
                        {
                            <button class="carousel-control-prev" type="button" data-bs-target="#photoCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Poprzednie</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#photoCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Następne</span>
                            </button>
                        }
                    </div>
                </div>
            }

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Opis</h5>
                </div>
                <div class="card-body">
                    <p class="mb-0">@(string.IsNullOrEmpty(Model.Description) ? "Brak opisu." : Model.Description)</p>
                </div>
            </div>

            @if (Model.Tags != null && Model.Tags.Any())
            {
                <div class="mb-4">
                    <h5>Tagi:</h5>
                    <div>
                        @foreach (var tag in Model.Tags)
                        {
                            <span class="badge bg-secondary me-2">@tag.Tag.Name</span>
                        }
                    </div>
                </div>
            }

            @if (!Model.NotExchangeable && (Model.ExchangeDescription != null || (Model.ExchangeAcceptedTags != null && Model.ExchangeAcceptedTags.Any()) || Model.MinExchangeValue.HasValue))
            {
                <div class="card mb-4 border-info">
                    <div class="card-header">Wymiana</div>
                    <div class="card-body">
                        @if (Model.MinExchangeValue.HasValue)
                        {
                            <p class="mb-2"><strong>Minimalna wartość oferty kupującego:</strong> @Model.MinExchangeValue.Value.ToString("C")</p>
                        }
                        @if (Model.ExchangeAcceptedTags != null && Model.ExchangeAcceptedTags.Any())
                        {
                            <p class="mb-1"><strong>Akceptowane tagi przy wymianie:</strong></p>
                            <div class="mb-2">
                                @foreach (var et in Model.ExchangeAcceptedTags)
                                {
                                    <span class="badge bg-info text-dark me-1">@et.Tag.Name</span>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.ExchangeDescription))
                        {
                            <p class="mb-0"><strong>Czego szukam w zamian:</strong> @Model.ExchangeDescription</p>
                        }
                    </div>
                </div>
            }
            else if (Model.NotExchangeable)
            {
                <p class="text-muted"><span class="badge bg-dark">Nie do wymiany</span> To ogłoszenie nie jest uwzględniane w propozycjach wymiany.</p>
            }

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Opinie</h5>
                </div>
                <div class="card-body">
                    @if (User.Identity.IsAuthenticated && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value != Model.SellerId.ToString())
                    {
                        <a asp-controller="Reviews" asp-action="Create" asp-route-listingId="@Model.Id" class="btn btn-primary btn-sm mb-3">Dodaj opinię</a>
                    }

                    @if (Model.Reviews != null && Model.Reviews.Any())
                    {
                        @foreach (var review in Model.Reviews)
                        {
                            <div class="border-bottom pb-3 mb-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <h6 class="mb-0">
                                            <a asp-controller="UserProfile" asp-action="Details" asp-route-id="@review.ReviewerId" class="text-decoration-none">
                                                @review.Reviewer.Username
                                            </a>
                                        </h6>
                                        <small class="text-muted">@review.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                                    </div>
                                    <div>
                                        @for (int i = 0; i < review.Rating; i++)
                                        {
                                            <span class="text-warning">⭐</span>
                                        }
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(review.Description))
                                {
                                    <p class="mb-2">@review.Description</p>
                                }
                                @if (review.Photos != null && review.Photos.Any())
                                {
                                    <div class="d-flex gap-2 flex-wrap">
                                        @foreach (var photo in review.Photos)
                                        {
                                            <img src="@photo.Upload.Url" alt="Zdjęcie z opinii" class="img-thumbnail" style="max-width: 100px; max-height: 100px;">
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted mb-0">Brak opinii. @(!isUserSeller ? "Bądź pierwszy!" : "")</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm sticky-top" style="top: 20px;">
                <div class="card-body">
                    <h5 class="card-title">Szczegóły</h5>
                    @if (Model.IsArchived)
                    {
                        <div class="alert alert-secondary mb-2">
                            <strong>Ogłoszenie zarchiwizowane</strong>
                        </div>
                    }

                    <hr />

                    @if (!string.IsNullOrEmpty(Model.Location))
                    {
                        <div class="mb-3">
                            <strong>📍 Lokalizacja:</strong>
                            <span>@Model.Location</span>
                        </div>
                    }

                    <div class="mb-3">
                        <strong>Cena:</strong>
                        @if (Model.Price.HasValue)
                        {
                            <span class="@(Model.IsArchived ? "text-muted fs-4" : "text-primary fs-4")">@Model.Price.Value.ToString("C")</span>
                        }
                        else
                        {
                            <span class="badge bg-@(Model.IsArchived ? "secondary" : "info")">Wymiana</span>
                        }
                    </div>

                    <div class="mb-3">
                        <strong>Typ:</strong>
                        <span class="badge bg-@(Model.IsArchived ? "secondary" : Model.Type == ListingType.Sale ? "success" : "info")">
                            @(Model.Type == ListingType.Sale ? "Sprzedaż" : "Wymiana")
                        </span>
                    </div>

                    <div class="mb-3">
                        <strong>Dostępna ilość:</strong>
                        <span class="@(Model.StockQuantity > 0 ? "" : "text-danger")">@Model.StockQuantity szt.</span>
                    </div>

                    <div class="mb-3">
                        <strong>Wyświetlenia:</strong>
                        <span class="text-muted">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" class="bi bi-eye me-1" viewBox="0 0 16 16">
                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                            </svg>@Model.ViewCount
                        </span>
                    </div>

                    <div class="mb-3">
                        <strong>Sprzedawca:</strong><br />
                        <a asp-controller="UserProfile" asp-action="Details" asp-route-id="@Model.SellerId" class="text-decoration-none">
                            @Model.Seller.Username
                        </a>
                        @if (!Model.IsArchived && !isUserSeller)
                        {
                            <div class="mt-2">
                                <a asp-controller="Messages"
                                asp-action="Conversation"
                                asp-route-userId="@Model.SellerId"
                                asp-route-listingId="@Model.Id"
                                class="btn btn-outline-primary btn-sm w-100">
                                    Skontaktuj się ze sprzedawcą
                                </a>
                            </div>
                            @if (isUserAuthenticated && !Model.NotExchangeable && !Model.IsSold && Model.StockQuantity > 0)
                            {
                                <div class="mt-2">
                                    <a asp-controller="TradeProposals"
                                       asp-action="Compose"
                                       asp-route-listingId="@Model.Id"
                                       class="btn btn-success btn-sm w-100">
                                        Wymień się
                                    </a>
                                </div>
                            }
                        }
                    </div>

                    <div class="mb-3">
                        <strong>Data utworzenia:</strong><br />
                        <small class="text-muted">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                    </div>

                    <div class="mb-3">
                        <strong>Liczba wyświetleń:</strong><br />
                        <small class="text-muted">@Model.ViewCount</small>
                    </div>

                    <hr />

                    @if (Model.IsArchived)
                    {
                        <button class="btn btn-secondary w-100 btn-lg mb-2" disabled>
                            Ogłoszenie niedostępne
                        </button>
                    }

                    else if (Model.IsSold || Model.StockQuantity <= 0)
                    {
                        <div class="alert alert-danger mb-2">
                            <strong>Sprzedane</strong>
                        </div>
                    }
                    else if (isUserSeller)
                    {
                        <a asp-controller="ListingManage" asp-action="EditListing" asp-route-id="@Model.Id" class="btn btn-primary w-100 btn-lg">Edit</a>
                        <hr/>
                        <form asp-controller="ListingManage" asp-action="ArchiveListing" asp-route-id="@Model.Id" method="post" class="mb-2">
                            <button type="submit" class="btn @(Model.IsArchived ? "btn-outline-success" : "btn-outline-secondary") w-100">
                                @(Model.IsArchived ? "Przywróć ogłoszenie" : "Archiwizuj ogłoszenie")
                            </button>
                        </form>
                        <hr />
                        <form asp-controller="ListingManage" asp-action="DeleteListing" asp-route-id="item.Listing.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this listing?');">
                            <button type="submit" class="btn btn-danger w-100 btn-lg">Delete</button>
                        </form>
                    }
                    else if (!Model.IsSold && Model.StockQuantity > 0 && Model.Type == ListingType.Sale)
                    {
                        @if (TempData["BuyError"] != null)
                        {
                            <div class="alert alert-warning py-2 mb-2">@TempData["BuyError"]</div>
                        }
                        <form asp-controller="Payment" asp-action="Buy" method="post" class="mb-2" id="buy-form">
                            <input type="hidden" name="listingId" value="@Model.Id" />
                            <div class="mb-2">
                                <label for="buy-quantity" class="form-label small mb-0">Ilość</label>
                                <input id="buy-quantity" name="quantity" type="number" class="form-control" value="1" min="1" max="@Model.StockQuantity" required />
                            </div>

                            @if (Model.ShippingOptions != null && Model.ShippingOptions.Any())
                            {
                                <div class="mb-3">
                                    <label class="form-label small fw-bold mb-1">🚚 Dostawa</label>
                                    @foreach (var opt in Model.ShippingOptions)
                                    {
                                        <div class="form-check">
                                            <input class="form-check-input shipping-radio"
                                                   type="radio"
                                                   name="shippingOptionId"
                                                   id="ship-@opt.Id"
                                                   value="@opt.Id"
                                                   data-price="@opt.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                                   required />
                                            <label class="form-check-label" for="ship-@opt.Id">
                                                @opt.Name
                                                @if (opt.Price == 0)
                                                {
                                                    <span class="badge bg-success ms-1">Gratis</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">— @opt.Price.ToString("C")</span>
                                                }
                                            </label>
                                        </div>
                                    }
                                </div>

                                <div class="alert alert-light border py-2 mb-2" id="price-summary">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted small">Przedmiot</span>
                                        <span id="item-total" class="small">@((Model.Price ?? 0).ToString("C"))</span>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted small">Dostawa</span>
                                        <span id="ship-total" class="small">—</span>
                                    </div>
                                    <hr class="my-1" />
                                    <div class="d-flex justify-content-between fw-bold">
                                        <span>Razem</span>
                                        <span id="grand-total">—</span>
                                    </div>
                                </div>
                            }

                            <button type="submit" class="btn btn-primary w-100 btn-lg">
                                Kup teraz
                            </button>
                        </form>

                        @if (Model.ShippingOptions != null && Model.ShippingOptions.Any())
                        {
                            <script>
                                const basePrice = @((Model.Price ?? 0).ToString("F2", System.Globalization.CultureInfo.InvariantCulture));
                                const formatPLN = v => v.toLocaleString('pl-PL', { style: 'currency', currency: 'PLN' });
                                document.querySelectorAll('.shipping-radio').forEach(r => {
                                    r.addEventListener('change', updateTotal);
                                });
                                document.getElementById('buy-quantity').addEventListener('input', updateTotal);
                                function updateTotal() {
                                    const qty = parseInt(document.getElementById('buy-quantity').value) || 1;
                                    const sel = document.querySelector('.shipping-radio:checked');
                                    const ship = sel ? parseFloat(sel.dataset.price) : 0;
                                    document.getElementById('item-total').textContent = formatPLN(basePrice * qty);
                                    document.getElementById('ship-total').textContent = sel ? (ship === 0 ? 'Gratis' : formatPLN(ship)) : '—';
                                    document.getElementById('grand-total').textContent = sel ? formatPLN(basePrice * qty + ship) : '—';
                                }
                            </script>
                        }
                    }

                    @if (!isUserSeller)
                    {
                        <a asp-controller="Tickets" asp-action="ReportListing" asp-route-listingId="@Model.Id" class="btn btn-outline-danger w-100">
                            Zgłoś ogłoszenie
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var listing = {
                id: '@Model.Id',
                title: '@Model.Title',
                image: '@(Model.Photos?.FirstOrDefault()?.Upload?.Url ?? "")'
            };

            var listingHistory = JSON.parse(localStorage.getItem('listingHistory') || '[]');

            listingHistory = listingHistory.filter(l => l.id !== listing.id);
            listingHistory.unshift(listing);
            listingHistory = listingHistory.slice(0, 5);

            localStorage.setItem('listingHistory', JSON.stringify(listingHistory));
        })();
    </script>
}